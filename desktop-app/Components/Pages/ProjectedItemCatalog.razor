@page "/projected-item-catalog"
@inject ProjectedItemCatalogClientService ProjectedCatalogClient

<PageTitle>Projected Item Catalog - OrganizedJihad</PageTitle>

<div class="container-fluid">
	<div class="row mb-4">
		<div class="col-12 d-flex justify-content-between align-items-start">
			<div>
				<h1 class="display-5 mb-1">Projected Item Catalog</h1>
				<p class="text-muted mb-0">Desktop parity view for canonical projection item metadata and alias mappings.</p>
			</div>
			<button class="btn btn-primary" @onclick="RefreshAsync" disabled="@IsLoading">
				@if (IsLoading) {
					<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
				}
				Refresh
			</button>
		</div>
	</div>

	@if (!string.IsNullOrWhiteSpace(StatusMessage)) {
		<div class="row mb-3">
			<div class="col-12">
				<div class="alert alert-secondary py-2 mb-0">
					<small>@StatusMessage</small>
				</div>
			</div>
		</div>
	}

	@if (Payload is not null) {
		<div class="row g-3 mb-4">
			<div class="col-md-3">
				<div class="card border-secondary h-100">
					<div class="card-body py-3">
						<div class="text-muted small">Generated (UTC)</div>
						<div class="fw-semibold">@Payload.GeneratedAtUtc.ToString("yyyy-MM-dd HH:mm:ss")</div>
					</div>
				</div>
			</div>
			<div class="col-md-3">
				<div class="card border-secondary h-100">
					<div class="card-body py-3">
						<div class="text-muted small">Canonical Items</div>
						<div class="fw-semibold">@Payload.Items.Count</div>
					</div>
				</div>
			</div>
			<div class="col-md-3">
				<div class="card border-secondary h-100">
					<div class="card-body py-3">
						<div class="text-muted small">Alias Mappings</div>
						<div class="fw-semibold">@Payload.Aliases.Count</div>
					</div>
				</div>
			</div>
			<div class="col-md-3">
				<div class="card border-secondary h-100">
					<div class="card-body py-3">
						<div class="text-muted small">Filtered Items</div>
						<div class="fw-semibold">@FilteredItems.Count</div>
					</div>
				</div>
			</div>
		</div>

		<div class="row g-3 mb-3">
			<div class="col-md-4">
				<label class="form-label">Search Item ID / Name</label>
				<input class="form-control" @bind="ItemSearch" @bind:event="oninput" placeholder="e.g., fragment or titan" />
			</div>
			<div class="col-md-3">
				<label class="form-label">Category</label>
				<select class="form-select" @bind="CategoryFilter">
					<option value="">All Categories</option>
					@foreach (var category in Categories) {
						<option value="@category">@category</option>
					}
				</select>
			</div>
			<div class="col-md-5">
				<label class="form-label">Alias Search</label>
				<input class="form-control" @bind="AliasSearch" @bind:event="oninput" placeholder="Filter alias keys or canonical values" />
			</div>
		</div>

		<div class="row g-4">
			<div class="col-lg-8">
				<div class="card">
					<div class="card-header d-flex justify-content-between align-items-center">
						<h5 class="mb-0">Canonical Items</h5>
						<span class="badge bg-secondary">@FilteredItems.Count</span>
					</div>
					<div class="card-body p-0">
						@if (FilteredItems.Any()) {
							<div class="table-responsive">
								<table class="table table-sm table-striped align-middle mb-0">
									<thead>
										<tr>
											<th>Item ID</th>
											<th>Name</th>
											<th>Category</th>
											<th>Icon</th>
										</tr>
									</thead>
									<tbody>
										@foreach (var item in FilteredItems.Take(500)) {
											<tr>
												<td><code>@item.ItemId</code></td>
												<td>@item.DisplayName</td>
												<td><span class="badge bg-dark">@item.Category</span></td>
												<td>@item.Icon</td>
											</tr>
										}
									</tbody>
								</table>
							</div>
							@if (FilteredItems.Count > 500) {
								<div class="text-center py-2 text-muted">
									<small>Showing first 500 of @FilteredItems.Count filtered items</small>
								</div>
							}
						} else {
							<div class="text-center py-4 text-muted">
								<p class="mb-0">No canonical items match current filters.</p>
							</div>
						}
					</div>
				</div>
			</div>

			<div class="col-lg-4">
				<div class="card">
					<div class="card-header d-flex justify-content-between align-items-center">
						<h5 class="mb-0">Alias Preview</h5>
						<span class="badge bg-secondary">@FilteredAliases.Count</span>
					</div>
					<div class="card-body p-0">
						@if (FilteredAliases.Any()) {
							<div class="table-responsive">
								<table class="table table-sm table-striped align-middle mb-0">
									<thead>
										<tr>
											<th>Alias</th>
											<th>Canonical</th>
										</tr>
									</thead>
									<tbody>
										@foreach (var alias in FilteredAliases.Take(300)) {
											<tr>
												<td><code>@alias.Key</code></td>
												<td><code>@alias.Value</code></td>
											</tr>
										}
									</tbody>
								</table>
							</div>
							@if (FilteredAliases.Count > 300) {
								<div class="text-center py-2 text-muted">
									<small>Showing first 300 of @FilteredAliases.Count aliases</small>
								</div>
							}
						} else {
							<div class="text-center py-4 text-muted">
								<p class="mb-0">No aliases match current filter.</p>
							</div>
						}
					</div>
				</div>
			</div>
		</div>
	} else {
		<div class="row">
			<div class="col-12 text-center py-5 text-muted">
				<p class="mb-0">Projected item catalog data is not loaded yet.</p>
				<small>Use Refresh to query the API endpoint.</small>
			</div>
		</div>
	}
</div>

@code {
	private bool IsLoading { get; set; }
	private string StatusMessage { get; set; } = string.Empty;
	private string ItemSearch { get; set; } = string.Empty;
	private string AliasSearch { get; set; } = string.Empty;
	private string CategoryFilter { get; set; } = string.Empty;
	private ProjectedItemCatalogResponseModel? Payload { get; set; }

	private List<string> Categories => Payload?.Items
		.Select(i => i.Category)
		.Where(c => !string.IsNullOrWhiteSpace(c))
		.Distinct(StringComparer.OrdinalIgnoreCase)
		.OrderBy(c => c)
		.ToList() ?? [];

	private List<ProjectedItemCatalogEntryModel> FilteredItems => Payload?.Items
		.Where(i => string.IsNullOrWhiteSpace(CategoryFilter) || string.Equals(i.Category, CategoryFilter, StringComparison.OrdinalIgnoreCase))
		.Where(i => string.IsNullOrWhiteSpace(ItemSearch)
			|| i.ItemId.Contains(ItemSearch, StringComparison.OrdinalIgnoreCase)
			|| i.DisplayName.Contains(ItemSearch, StringComparison.OrdinalIgnoreCase)
			|| i.Category.Contains(ItemSearch, StringComparison.OrdinalIgnoreCase))
		.OrderBy(i => i.ItemId)
		.ToList() ?? [];

	private List<KeyValuePair<string, string>> FilteredAliases => Payload?.Aliases
		.Where(a => string.IsNullOrWhiteSpace(AliasSearch)
			|| a.Key.Contains(AliasSearch, StringComparison.OrdinalIgnoreCase)
			|| a.Value.Contains(AliasSearch, StringComparison.OrdinalIgnoreCase))
		.OrderBy(a => a.Key)
		.ToList() ?? [];

	protected override async Task OnInitializedAsync() {
		await RefreshAsync();
	}

	private async Task RefreshAsync() {
		try {
			IsLoading = true;
			var result = await ProjectedCatalogClient.GetProjectedItemCatalogAsync();
			Payload = result.Payload;
			StatusMessage = result.Message;
		} finally {
			IsLoading = false;
		}
	}
}
