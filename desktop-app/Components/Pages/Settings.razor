@page "/settings"
@inject RecommendationSettingsService RecommendationSettings
@using System.Net.Http.Json

<PageTitle>Settings - OrganizedJihad</PageTitle>

<div class="container-fluid">
	<div class="row mb-4">
		<div class="col-12">
			<h1 class="display-5">Settings</h1>
			<p class="text-muted">Configure local endpoints and recommendation behavior.</p>
		</div>
	</div>

	<div class="row">
		<div class="col-lg-8">
			<div class="card">
				<div class="card-header">
					<h5 class="mb-0">Recommendation API</h5>
				</div>
				<div class="card-body">
					<div class="mb-3">
						<label class="form-label">API Base URL</label>
						<input class="form-control" @bind="RecommendationApiBaseUrl" placeholder="http://localhost:5124" />
						<div class="form-text">Used by dashboard recommendation cards for shared API scoring.</div>
					</div>

					<div class="d-flex gap-2">
						<button class="btn btn-primary" @onclick="SaveAsync">Save</button>
						<button class="btn btn-outline-secondary" @onclick="ResetToDefaultAsync">Reset Default</button>
					</div>

					@if (!string.IsNullOrWhiteSpace(StatusMessage)) {
						<div class="alert alert-info mt-3 py-2 mb-0">
							<small>@StatusMessage</small>
						</div>
					}
				</div>
			</div>
		</div>
	</div>

	<div class="row mt-4">
		<div class="col-lg-10">
			<div class="card border-primary">
				<div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
					<h5 class="mb-0">Team Recommendation Calibration</h5>
					<button class="btn btn-sm btn-light" @onclick="RefreshTeamRecommendationAsync">Refresh</button>
				</div>
				<div class="card-body">
					@if (!string.IsNullOrWhiteSpace(TeamRecommendationStatusMessage)) {
						<div class="alert alert-secondary py-2 mb-3">
							<small>@TeamRecommendationStatusMessage</small>
						</div>
					}

					@if (TeamRecommendationModePreferences.Any()) {
						<div class="table-responsive mb-3">
							<table class="table table-sm align-middle mb-0">
								<thead>
									<tr>
										<th>Mode</th>
										<th>Preferred Trend Window</th>
										<th>Supported</th>
									</tr>
								</thead>
								<tbody>
									@foreach (var modePreference in TeamRecommendationModePreferences) {
										<tr>
											<td><strong>@modePreference.Mode</strong></td>
											<td>
												<select class="form-select form-select-sm"
													value="@modePreference.PreferredTrendWindowDays"
													@onchange="@(args => SaveModeTrendPreferenceAsync(modePreference.Mode, args))">
													@foreach (var window in modePreference.SupportedTrendWindowDays.Distinct().OrderBy(w => w)) {
														<option value="@window">@window days</option>
													}
												</select>
											</td>
											<td><small>@string.Join(", ", modePreference.SupportedTrendWindowDays.Distinct().OrderBy(w => w))</small></td>
										</tr>
									}
								</tbody>
							</table>
						</div>
					}

					<div class="row g-2 mb-3">
						<div class="col-md-4">
							<label class="form-label">Calibration Mode</label>
							<select class="form-select" @bind="SelectedCalibrationMode" @bind:after="RefreshTeamCalibrationAsync">
								@foreach (var mode in TeamRecommendationModePreferences.Select(m => m.Mode).Distinct(StringComparer.OrdinalIgnoreCase).OrderBy(m => m)) {
									<option value="@mode">@mode</option>
								}
							</select>
						</div>
					</div>

					@if (TeamCalibration is not null) {
						<div class="row">
							<div class="col-md-6">
								<div><strong>Suggested Friction Scale:</strong> @TeamCalibration.SuggestedFrictionScale.ToString("F3")</div>
								<div><strong>Preferred Trend Window:</strong> @TeamCalibration.PreferredTrendWindowDays days</div>
								<div><strong>Samples:</strong> @TeamCalibration.Samples</div>
							</div>
							<div class="col-md-6">
								<div><strong>MAE:</strong> @((TeamCalibration.MeanAbsoluteError * 100).ToString("F2"))%</div>
								<div><strong>Brier:</strong> @((TeamCalibration.MeanBrierScore * 100).ToString("F2"))%</div>
								<div><strong>Bias:</strong> @TeamCalibration.PredictionBias.ToString("F4")</div>
							</div>
						</div>

						@if (TeamCalibration.TrendWindows.Any()) {
							<div class="table-responsive mt-3">
								<table class="table table-sm table-striped mb-0">
									<thead>
										<tr>
											<th>Window</th>
											<th>Samples</th>
											<th>Scale</th>
											<th>MAE</th>
											<th>Brier</th>
											<th>Bias</th>
										</tr>
									</thead>
									<tbody>
										@foreach (var trend in TeamCalibration.TrendWindows.OrderBy(t => t.WindowDays)) {
											<tr>
												<td>@trend.WindowDays d</td>
												<td>@trend.Samples</td>
												<td>@trend.SuggestedFrictionScale.ToString("F3")</td>
												<td>@((trend.MeanAbsoluteError * 100).ToString("F2"))%</td>
												<td>@((trend.MeanBrierScore * 100).ToString("F2"))%</td>
												<td>@trend.PredictionBias.ToString("F4")</td>
											</tr>
										}
									</tbody>
								</table>
							</div>
						}
					}
				</div>
			</div>
		</div>
	</div>

	<div class="row mt-4">
		<div class="col-lg-10">
			<div class="card border-info">
				<div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
					<h5 class="mb-0">External Tool Catalog</h5>
					<button class="btn btn-sm btn-light" @onclick="RefreshCatalogAsync">Refresh</button>
				</div>
				<div class="card-body">
					<div class="row g-2 mb-3">
						<div class="col-md-3">
							<label class="form-label">Min Confidence</label>
							<input type="number" class="form-control" min="0" max="1" step="0.05" @bind="CatalogMinConfidence" />
						</div>
						<div class="col-md-3">
							<label class="form-label">Category</label>
							<select class="form-select" @bind="CatalogCategory">
								<option value="">All</option>
								@foreach (var category in CatalogCategories) {
									<option value="@category">@category</option>
								}
							</select>
						</div>
						<div class="col-md-3">
							<label class="form-label">Verification</label>
							<select class="form-select" @bind="CatalogVerificationStatus">
								<option value="">All</option>
								@foreach (var status in CatalogVerificationStatuses) {
									<option value="@status">@status</option>
								}
							</select>
						</div>
						<div class="col-md-3">
							<label class="form-label">Sort</label>
							<select class="form-select" @bind="CatalogSort">
								@foreach (var sortOption in CatalogSortOptions) {
									<option value="@sortOption">@sortOption</option>
								}
							</select>
						</div>
						<div class="col-md-12 d-flex align-items-end">
							<div class="form-check">
								<input class="form-check-input" type="checkbox" id="catalogIncludeStale" @bind="CatalogIncludeStale" />
								<label class="form-check-label" for="catalogIncludeStale">Include stale</label>
							</div>
						</div>
					</div>

					@if (!string.IsNullOrWhiteSpace(CatalogStatusMessage)) {
						<div class="alert alert-secondary py-2">
							<small>@CatalogStatusMessage</small>
						</div>
					}

					@if (ToolCatalog.Any()) {
						<div class="table-responsive">
							<table class="table table-sm table-striped align-middle mb-0">
								<thead>
									<tr>
										<th>Name</th>
										<th>Category</th>
										<th>Status</th>
										<th>Confidence</th>
										<th>Last Reviewed (UTC)</th>
										<th>Capabilities</th>
										<th>Caveats</th>
										<th>Link</th>
									</tr>
								</thead>
								<tbody>
									@foreach (var tool in ToolCatalog) {
										<tr>
											<td><strong>@tool.Name</strong></td>
											<td><span class="badge bg-secondary">@tool.Category</span></td>
											<td>
												<span class="badge @GetStatusBadgeClass(tool.VerificationStatus)">@tool.VerificationStatus</span>
											</td>
											<td>@((tool.ConfidenceScore * 100).ToString("F0"))%</td>
											<td>
												@tool.LastReviewedUtc.ToString("yyyy-MM-dd")
												@if (IsStale(tool.LastReviewedUtc)) {
													<div><small class="text-danger">stale</small></div>
												}
											</td>
											<td>@tool.Capabilities</td>
											<td><small>@tool.Caveats</small></td>
											<td><a class="btn btn-sm btn-outline-primary" href="@tool.Url" target="_blank">Open</a></td>
										</tr>
									}
								</tbody>
							</table>
						</div>
					} else {
						<p class="text-muted mb-0">No catalog entries loaded yet.</p>
					}
				</div>
			</div>
		</div>
	</div>

	<div class="row mt-4">
		<div class="col-lg-10">
			<div class="card border-secondary">
				<div class="card-header bg-secondary text-white d-flex justify-content-between align-items-center">
					<h5 class="mb-0">Projected Item Catalog Parity</h5>
					<button class="btn btn-sm btn-light" @onclick="RefreshProjectedItemCatalogAsync">Refresh</button>
				</div>
				<div class="card-body">
					@if (!string.IsNullOrWhiteSpace(ProjectedCatalogStatusMessage)) {
						<div class="alert alert-secondary py-2 mb-3">
							<small>@ProjectedCatalogStatusMessage</small>
						</div>
					}

					@if (ProjectedItemCatalog is not null) {
						<div class="row g-3 mb-3">
							<div class="col-md-3">
								<div class="border rounded p-2">
									<div class="text-muted small">Generated (UTC)</div>
									<div class="fw-semibold">@ProjectedItemCatalog.GeneratedAtUtc.ToString("yyyy-MM-dd HH:mm:ss")</div>
								</div>
							</div>
							<div class="col-md-3">
								<div class="border rounded p-2">
									<div class="text-muted small">Canonical Items</div>
									<div class="fw-semibold">@ProjectedItemCatalog.Items.Count</div>
								</div>
							</div>
							<div class="col-md-3">
								<div class="border rounded p-2">
									<div class="text-muted small">Alias Mappings</div>
									<div class="fw-semibold">@ProjectedItemCatalog.Aliases.Count</div>
								</div>
							</div>
							<div class="col-md-3">
								<div class="border rounded p-2">
									<div class="text-muted small">Sample Rows</div>
									<div class="fw-semibold">@ProjectedCatalogSampleRows.Count</div>
								</div>
							</div>
						</div>

						@if (ProjectedCatalogSampleRows.Any()) {
							<div class="table-responsive">
								<table class="table table-sm table-striped align-middle mb-0">
									<thead>
										<tr>
											<th>Item ID</th>
											<th>Name</th>
											<th>Category</th>
											<th>Icon</th>
										</tr>
									</thead>
									<tbody>
										@foreach (var item in ProjectedCatalogSampleRows) {
											<tr>
												<td><code>@item.ItemId</code></td>
												<td>@item.DisplayName</td>
												<td><span class="badge bg-dark">@item.Category</span></td>
												<td>@item.Icon</td>
											</tr>
										}
									</tbody>
								</table>
							</div>
						}
					} else {
						<p class="text-muted mb-0">Projected item catalog not loaded yet.</p>
					}
				</div>
			</div>
		</div>
	</div>
</div>

@code {
	private string RecommendationApiBaseUrl { get; set; } = string.Empty;
	private string StatusMessage { get; set; } = string.Empty;
	private string TeamRecommendationStatusMessage { get; set; } = string.Empty;
	private string CatalogStatusMessage { get; set; } = string.Empty;
	private string ProjectedCatalogStatusMessage { get; set; } = string.Empty;
	private string SelectedCalibrationMode { get; set; } = "arena";
	private List<TeamRecommendationModePreferenceModel> TeamRecommendationModePreferences { get; set; } = [];
	private TeamRecommendationCalibrationResponseModel? TeamCalibration { get; set; }
	private List<ToolCatalogEntryModel> ToolCatalog { get; set; } = new();
	private List<string> CatalogCategories { get; set; } = ["simulator", "calculator", "guides", "extension"];
	private List<string> CatalogVerificationStatuses { get; set; } = ["verified", "partial", "unverified", "stale"];
	private List<string> CatalogSortOptions { get; set; } = ["confidence", "reviewed", "name"];
	private double CatalogMinConfidence { get; set; } = 0.65;
	private bool CatalogIncludeStale { get; set; } = false;
	private string CatalogCategory { get; set; } = string.Empty;
	private string CatalogVerificationStatus { get; set; } = string.Empty;
	private string CatalogSort { get; set; } = "confidence";
	private ProjectedItemCatalogResponseModel? ProjectedItemCatalog { get; set; }
	private List<ProjectedItemCatalogEntryModel> ProjectedCatalogSampleRows { get; set; } = [];

	protected override void OnInitialized() {
		RecommendationApiBaseUrl = RecommendationSettings.GetRecommendationApiBaseUrl();
		_ = InitializeTeamRecommendationAsync();
		_ = InitializeCatalogAsync();
		_ = InitializeProjectedItemCatalogAsync();
	}

	private async Task InitializeTeamRecommendationAsync() {
		await LoadTeamRecommendationPreferencesAsync();
		await RefreshTeamCalibrationAsync();
	}

	private async Task RefreshTeamRecommendationAsync() {
		await LoadTeamRecommendationPreferencesAsync();
		await RefreshTeamCalibrationAsync();
	}

	private async Task LoadTeamRecommendationPreferencesAsync() {
		try {
			var baseUrl = RecommendationSettings.GetRecommendationApiBaseUrl().TrimEnd('/');
			using var client = new HttpClient { Timeout = TimeSpan.FromSeconds(3) };
			var payload = await client.GetFromJsonAsync<TeamRecommendationTrendPreferenceResponseModel>($"{baseUrl}/api/sync/teams/recommendations/preferences");

			TeamRecommendationModePreferences = payload?.Modes
				?.Where(m => !string.IsNullOrWhiteSpace(m.Mode))
				.OrderBy(m => m.Mode)
				.ToList() ?? [];

			if (TeamRecommendationModePreferences.Count > 0 &&
				!TeamRecommendationModePreferences.Any(m => string.Equals(m.Mode, SelectedCalibrationMode, StringComparison.OrdinalIgnoreCase))) {
				SelectedCalibrationMode = TeamRecommendationModePreferences[0].Mode;
			}

			if (TeamRecommendationModePreferences.Count > 0) {
				TeamRecommendationStatusMessage = $"Loaded {TeamRecommendationModePreferences.Count} mode preference entries.";
			}
		} catch (Exception ex) {
			TeamRecommendationStatusMessage = $"Team Recommendation preferences unavailable: {ex.Message}";
			TeamRecommendationModePreferences = [];
		}
	}

	private async Task SaveModeTrendPreferenceAsync(string mode, ChangeEventArgs args) {
		if (string.IsNullOrWhiteSpace(mode)) {
			return;
		}

		if (!int.TryParse(args?.Value?.ToString(), out var preferredTrendWindowDays)) {
			return;
		}

		if (preferredTrendWindowDays is not (7 or 30 or 90)) {
			return;
		}

		try {
			var baseUrl = RecommendationSettings.GetRecommendationApiBaseUrl().TrimEnd('/');
			using var client = new HttpClient { Timeout = TimeSpan.FromSeconds(3) };
			var response = await client.PutAsJsonAsync(
				$"{baseUrl}/api/sync/teams/recommendations/preferences",
				new TeamRecommendationTrendPreferenceUpdateRequestModel {
					Mode = mode,
					PreferredTrendWindowDays = preferredTrendWindowDays,
				});

			if (!response.IsSuccessStatusCode) {
				TeamRecommendationStatusMessage = $"Failed to save preference for {mode}: HTTP {(int)response.StatusCode}";
				return;
			}

			SelectedCalibrationMode = mode;
			TeamRecommendationStatusMessage = $"Saved trend window preference for {mode}: {preferredTrendWindowDays}d";
			await RefreshTeamRecommendationAsync();
		} catch (Exception ex) {
			TeamRecommendationStatusMessage = $"Save failed for {mode}: {ex.Message}";
		}
	}

	private async Task RefreshTeamCalibrationAsync() {
		if (string.IsNullOrWhiteSpace(SelectedCalibrationMode)) {
			TeamCalibration = null;
			return;
		}

		try {
			var baseUrl = RecommendationSettings.GetRecommendationApiBaseUrl().TrimEnd('/');
			using var client = new HttpClient { Timeout = TimeSpan.FromSeconds(3) };
			var payload = await client.GetFromJsonAsync<TeamRecommendationCalibrationResponseModel>($"{baseUrl}/api/sync/teams/recommendations/calibration?mode={Uri.EscapeDataString(SelectedCalibrationMode)}");
			TeamCalibration = payload;
		} catch (Exception ex) {
			TeamRecommendationStatusMessage = $"Calibration unavailable for {SelectedCalibrationMode}: {ex.Message}";
			TeamCalibration = null;
		}
	}

	private async Task InitializeCatalogAsync() {
		await LoadCatalogFilterMetadataAsync();
		await RefreshCatalogAsync();
	}

	private async Task InitializeProjectedItemCatalogAsync() {
		await RefreshProjectedItemCatalogAsync();
	}

	private Task SaveAsync() {
		var saved = RecommendationSettings.SaveRecommendationApiBaseUrl(RecommendationApiBaseUrl);
		RecommendationApiBaseUrl = saved;
		StatusMessage = $"Saved recommendation API URL: {saved}";
		return Task.CompletedTask;
	}

	private Task ResetToDefaultAsync() {
		var saved = RecommendationSettings.SaveRecommendationApiBaseUrl("http://localhost:5124");
		RecommendationApiBaseUrl = saved;
		StatusMessage = "Recommendation API URL reset to default.";
		return Task.CompletedTask;
	}

	private async Task RefreshCatalogAsync() {
		try {
			var baseUrl = RecommendationSettings.GetRecommendationApiBaseUrl().TrimEnd('/');
			var query = new List<string> {
				$"minConfidence={CatalogMinConfidence.ToString(System.Globalization.CultureInfo.InvariantCulture)}",
				$"includeStale={CatalogIncludeStale.ToString().ToLowerInvariant()}",
				$"sort={Uri.EscapeDataString(CatalogSort)}",
			};

			if (!string.IsNullOrWhiteSpace(CatalogCategory)) {
				query.Add($"category={Uri.EscapeDataString(CatalogCategory)}");
			}

			if (!string.IsNullOrWhiteSpace(CatalogVerificationStatus)) {
				query.Add($"verificationStatus={Uri.EscapeDataString(CatalogVerificationStatus)}");
			}

			using var client = new HttpClient { Timeout = TimeSpan.FromSeconds(3) };
			var response = await client.GetFromJsonAsync<ToolCatalogResponseModel>($"{baseUrl}/api/sync/tools/catalog?{string.Join("&", query)}");

			ToolCatalog = response?.Tools ?? [];
			CatalogStatusMessage = ToolCatalog.Count > 0
				? $"Loaded {ToolCatalog.Count} tools from API catalog."
				: "Catalog loaded, but no tools were returned.";
		} catch (Exception ex) {
			CatalogStatusMessage = $"Catalog unavailable: {ex.Message}";
			ToolCatalog = [];
		}
	}

	private async Task LoadCatalogFilterMetadataAsync() {
		try {
			var baseUrl = RecommendationSettings.GetRecommendationApiBaseUrl().TrimEnd('/');
			using var client = new HttpClient { Timeout = TimeSpan.FromSeconds(3) };
			var response = await client.GetFromJsonAsync<ToolCatalogFilterMetadataModel>($"{baseUrl}/api/sync/tools/catalog/filters");

			if (response is null) {
				return;
			}

			CatalogCategories = response.Categories?.Where(s => !string.IsNullOrWhiteSpace(s)).Distinct(StringComparer.OrdinalIgnoreCase).ToList() ?? CatalogCategories;
			CatalogVerificationStatuses = response.VerificationStatuses?.Where(s => !string.IsNullOrWhiteSpace(s)).Distinct(StringComparer.OrdinalIgnoreCase).ToList() ?? CatalogVerificationStatuses;
			CatalogSortOptions = response.SortOptions?.Where(s => !string.IsNullOrWhiteSpace(s)).Distinct(StringComparer.OrdinalIgnoreCase).ToList() ?? CatalogSortOptions;

			if (response.DefaultMinConfidence >= 0d && response.DefaultMinConfidence <= 1d) {
				CatalogMinConfidence = response.DefaultMinConfidence;
			}

			CatalogIncludeStale = response.DefaultIncludeStale;

			if (!string.IsNullOrWhiteSpace(response.DefaultSort)) {
				CatalogSort = response.DefaultSort;
			}
		} catch {
			// Keep local fallback options when metadata endpoint is unavailable.
		}
	}

	private async Task RefreshProjectedItemCatalogAsync() {
		try {
			var baseUrl = RecommendationSettings.GetRecommendationApiBaseUrl().TrimEnd('/');
			using var client = new HttpClient { Timeout = TimeSpan.FromSeconds(3) };
			var payload = await client.GetFromJsonAsync<ProjectedItemCatalogResponseModel>($"{baseUrl}/api/sync/projections/item-catalog");

			ProjectedItemCatalog = payload;
			ProjectedCatalogSampleRows = payload?.Items
				.OrderBy(i => i.ItemId)
				.Take(20)
				.ToList() ?? [];

			ProjectedCatalogStatusMessage = payload is null
				? "Projected item catalog endpoint returned no payload."
				: $"Loaded {payload.Items.Count} canonical items and {payload.Aliases.Count} aliases.";
		} catch (Exception ex) {
			ProjectedItemCatalog = null;
			ProjectedCatalogSampleRows = [];
			ProjectedCatalogStatusMessage = $"Projected item catalog unavailable: {ex.Message}";
		}
	}

	private sealed class ToolCatalogResponseModel {
		public List<ToolCatalogEntryModel> Tools { get; set; } = [];
	}

	private sealed class ToolCatalogEntryModel {
		public string Name { get; set; } = string.Empty;
		public string Url { get; set; } = string.Empty;
		public string Category { get; set; } = string.Empty;
		public string VerificationStatus { get; set; } = string.Empty;
		public double ConfidenceScore { get; set; }
		public DateTime LastReviewedUtc { get; set; }
		public string Capabilities { get; set; } = string.Empty;
		public string Caveats { get; set; } = string.Empty;
	}

	private sealed class ToolCatalogFilterMetadataModel {
		public List<string> Categories { get; set; } = [];
		public List<string> VerificationStatuses { get; set; } = [];
		public List<string> SortOptions { get; set; } = [];
		public double DefaultMinConfidence { get; set; }
		public bool DefaultIncludeStale { get; set; }
		public string DefaultSort { get; set; } = string.Empty;
	}

	private sealed class TeamRecommendationTrendPreferenceResponseModel {
		public List<TeamRecommendationModePreferenceModel> Modes { get; set; } = [];
	}

	private sealed class TeamRecommendationModePreferenceModel {
		public string Mode { get; set; } = string.Empty;
		public int PreferredTrendWindowDays { get; set; } = 30;
		public List<int> SupportedTrendWindowDays { get; set; } = [7, 30, 90];
	}

	private sealed class TeamRecommendationTrendPreferenceUpdateRequestModel {
		public string Mode { get; set; } = "arena";
		public int PreferredTrendWindowDays { get; set; } = 30;
	}

	private sealed class TeamRecommendationCalibrationResponseModel {
		public string Mode { get; set; } = "arena";
		public double SuggestedFrictionScale { get; set; }
		public double MeanAbsoluteError { get; set; }
		public double MeanBrierScore { get; set; }
		public double PredictionBias { get; set; }
		public int Samples { get; set; }
		public int PreferredTrendWindowDays { get; set; } = 30;
		public List<TeamRecommendationCalibrationTrendWindowModel> TrendWindows { get; set; } = [];
	}

	private sealed class TeamRecommendationCalibrationTrendWindowModel {
		public int WindowDays { get; set; }
		public int Samples { get; set; }
		public double MeanAbsoluteError { get; set; }
		public double MeanBrierScore { get; set; }
		public double PredictionBias { get; set; }
		public double SuggestedFrictionScale { get; set; }
	}

	private sealed class ProjectedItemCatalogResponseModel {
		public DateTime GeneratedAtUtc { get; set; }
		public List<ProjectedItemCatalogEntryModel> Items { get; set; } = [];
		public Dictionary<string, string> Aliases { get; set; } = [];
	}

	private sealed class ProjectedItemCatalogEntryModel {
		public string ItemId { get; set; } = string.Empty;
		public string DisplayName { get; set; } = string.Empty;
		public string Category { get; set; } = string.Empty;
		public string Icon { get; set; } = string.Empty;
	}

	private static bool IsStale(DateTime lastReviewedUtc) {
		if (lastReviewedUtc == default) {
			return true;
		}

		return (DateTime.UtcNow - lastReviewedUtc).TotalDays > 90;
	}

	private static string GetStatusBadgeClass(string status) {
		var normalized = (status ?? string.Empty).Trim().ToLowerInvariant();
		return normalized switch {
			"verified" => "bg-success",
			"partial" => "bg-warning text-dark",
			"stale" => "bg-danger",
			_ => "bg-secondary",
		};
	}
}
