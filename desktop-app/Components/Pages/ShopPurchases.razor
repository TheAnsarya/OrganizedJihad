@page "/shop-purchases"
@using OrganizedJihad.Data
@using OrganizedJihad.Data.Models
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<GameDatabaseContext> DbFactory

<PageTitle>Shop Purchases - OrganizedJihad</PageTitle>

<div class="container-fluid">
	<div class="row mb-4">
		<div class="col-12">
			<h1 class="display-5">Shop & Merchant Purchases</h1>
			<p class="text-muted">Track all purchases from arena, guild, tower, merchant, and outland shops.</p>
		</div>
	</div>

	@if (IsLoading) {
		<div class="row">
			<div class="col-12 text-center py-5">
				<div class="spinner-border" role="status">
					<span class="visually-hidden">Loading...</span>
				</div>
			</div>
		</div>
	} else {
		<!-- Summary Cards -->
		<div class="row mb-4">
			<div class="col-md-3">
				<div class="card text-white bg-primary">
					<div class="card-body py-2">
						<h6 class="card-title mb-0">Total Purchases</h6>
						<p class="card-text display-6 mb-0">@AllPurchases.Count</p>
					</div>
				</div>
			</div>
			<div class="col-md-3">
				<div class="card text-white bg-success">
					<div class="card-body py-2">
						<h6 class="card-title mb-0">Total Spent (Gold)</h6>
						<p class="card-text display-6 mb-0">@TotalGoldSpent.ToString("N0")</p>
					</div>
				</div>
			</div>
			<div class="col-md-3">
				<div class="card text-white bg-warning">
					<div class="card-body py-2">
						<h6 class="card-title mb-0">Total Spent (Emeralds)</h6>
						<p class="card-text display-6 mb-0">@TotalEmeraldsSpent.ToString("N0")</p>
					</div>
				</div>
			</div>
			<div class="col-md-3">
				<div class="card text-white bg-info">
					<div class="card-body py-2">
						<h6 class="card-title mb-0">Shop Types</h6>
						<p class="card-text display-6 mb-0">@ShopTypeSummary.Count</p>
					</div>
				</div>
			</div>
		</div>

		<!-- Filters -->
		<div class="row mb-3">
			<div class="col-md-3">
				<select class="form-select" @bind="SelectedShop">
					<option value="">All Shops</option>
					@foreach (var s in ShopTypeSummary) {
						<option value="@s.ShopType">@FormatShopName(s.ShopType) (@s.Count)</option>
					}
				</select>
			</div>
			<div class="col-md-2">
				<select class="form-select" @bind="SelectedCurrency">
					<option value="">All Currencies</option>
					@foreach (var c in CurrencyTypes) {
						<option value="@c">@FormatCurrency(c)</option>
					}
				</select>
			</div>
			<div class="col-md-2">
				<input type="date" class="form-control" @bind="DateFrom" />
			</div>
			<div class="col-md-2">
				<input type="date" class="form-control" @bind="DateTo" />
			</div>
			<div class="col-md-3 d-flex align-items-end">
				<button class="btn btn-primary me-2" @onclick="ApplyFilters">Apply</button>
				<button class="btn btn-outline-secondary" @onclick="ClearFilters">Clear</button>
			</div>
		</div>

		<!-- Shop Type Breakdown -->
		@if (ShopTypeSummary.Any()) {
			<div class="row mb-4">
				<div class="col-md-6">
					<div class="card">
						<div class="card-header">
							<h5 class="mb-0">Purchases by Shop</h5>
						</div>
						<div class="card-body">
							@foreach (var shop in ShopTypeSummary) {
								var pct = AllPurchases.Count > 0 ? (int)((shop.Count / (double)AllPurchases.Count) * 100) : 0;
								<div class="mb-2">
									<div class="d-flex justify-content-between">
										<span class="fw-bold">@FormatShopName(shop.ShopType)</span>
										<span class="text-muted">@shop.Count purchases (@shop.TotalCost.ToString("N0") total)</span>
									</div>
									<div class="progress" style="height: 8px;">
										<div class="progress-bar bg-primary" style="width: @(pct)%"></div>
									</div>
								</div>
							}
						</div>
					</div>
				</div>
				<div class="col-md-6">
					<div class="card">
						<div class="card-header">
							<h5 class="mb-0">Spending by Currency</h5>
						</div>
						<div class="card-body">
							@{
								var currencySummary = AllPurchases
									.GroupBy(p => p.CostType)
									.Select(g => new { Currency = g.Key, Total = g.Sum(p => p.CostAmount), Count = g.Count() })
									.OrderByDescending(c => c.Total).ToList();
								var maxCost = currencySummary.Any() ? currencySummary.Max(c => c.Total) : 0;
							}
							@foreach (var c in currencySummary) {
								var pct = maxCost > 0 ? (int)((c.Total / (double)maxCost) * 100) : 0;
								<div class="mb-2">
									<div class="d-flex justify-content-between">
										<span class="fw-bold">@FormatCurrency(c.Currency)</span>
										<span class="text-muted">@c.Total.ToString("N0") (@c.Count purchases)</span>
									</div>
									<div class="progress" style="height: 8px;">
										<div class="progress-bar bg-warning" style="width: @(pct)%"></div>
									</div>
								</div>
							}
						</div>
					</div>
				</div>
			</div>
		}

		<!-- Purchase Log -->
		<div class="row">
			<div class="col-12">
				<div class="card">
					<div class="card-header d-flex justify-content-between align-items-center">
						<h5 class="mb-0">Purchase Log</h5>
						<span class="badge bg-secondary">@FilteredPurchases.Count records</span>
					</div>
					<div class="card-body p-0">
						@if (FilteredPurchases.Any()) {
							<div class="table-responsive">
								<table class="table table-striped table-hover mb-0">
									<thead class="table-dark">
										<tr>
											<th>Time</th>
											<th>Shop</th>
											<th>Item</th>
											<th class="text-end">Qty</th>
											<th>Cost</th>
											<th class="text-end">Amount</th>
										</tr>
									</thead>
									<tbody>
										@foreach (var p in FilteredPurchases.Take(200)) {
											<tr>
												<td><small>@p.PurchasedAt.ToString("MMM dd HH:mm")</small></td>
												<td>
													<span class="badge @GetShopBadgeClass(p.ShopType)">
														@FormatShopName(p.ShopType)
													</span>
												</td>
												<td><strong>@p.ItemName</strong></td>
												<td class="text-end">@p.Quantity</td>
												<td>
													<span class="badge @GetCurrencyBadgeClass(p.CostType)">
														@FormatCurrency(p.CostType)
													</span>
												</td>
												<td class="text-end fw-bold text-danger">-@p.CostAmount.ToString("N0")</td>
											</tr>
										}
									</tbody>
								</table>
							</div>
							@if (FilteredPurchases.Count > 200) {
								<div class="text-center py-2 text-muted">
									<small>Showing first 200 of @FilteredPurchases.Count purchases</small>
								</div>
							}
						} else {
							<div class="text-center py-5 text-muted">
								<p class="mb-0">No shop purchases recorded yet.</p>
								<small>Purchase data will appear after syncing from the browser extension.</small>
							</div>
						}
					</div>
				</div>
			</div>
		</div>
	}
</div>

@code {
	private bool IsLoading { get; set; } = true;
	private string SelectedShop { get; set; } = "";
	private string SelectedCurrency { get; set; } = "";
	private DateTime? DateFrom { get; set; }
	private DateTime? DateTo { get; set; }

	private List<ShopPurchase> AllPurchases { get; set; } = new();
	private List<ShopPurchase> FilteredPurchases { get; set; } = new();
	private List<ShopSummaryRow> ShopTypeSummary { get; set; } = new();
	private List<string> CurrencyTypes { get; set; } = new();
	private long TotalGoldSpent { get; set; }
	private long TotalEmeraldsSpent { get; set; }

	protected override async Task OnInitializedAsync() {
		await LoadData();
		IsLoading = false;
	}

	private async Task LoadData() {
		using var context = await DbFactory.CreateDbContextAsync();

		AllPurchases = await context.ShopPurchases.AsNoTracking()
			.OrderByDescending(p => p.PurchasedAt)
			.ToListAsync();

		ShopTypeSummary = AllPurchases
			.GroupBy(p => p.ShopType)
			.Select(g => new ShopSummaryRow {
				ShopType = g.Key,
				Count = g.Count(),
				TotalCost = g.Sum(p => p.CostAmount),
			})
			.OrderByDescending(s => s.Count)
			.ToList();

		CurrencyTypes = AllPurchases.Select(p => p.CostType)
			.Where(c => !string.IsNullOrEmpty(c))
			.Distinct()
			.OrderBy(c => c)
			.ToList();

		TotalGoldSpent = AllPurchases.Where(p => p.CostType == "gold").Sum(p => (long)p.CostAmount);
		TotalEmeraldsSpent = AllPurchases.Where(p => p.CostType == "emeralds").Sum(p => (long)p.CostAmount);

		ApplyFilters();
	}

	private void ApplyFilters() {
		var filtered = AllPurchases.AsEnumerable();

		if (!string.IsNullOrEmpty(SelectedShop))
			filtered = filtered.Where(p => p.ShopType == SelectedShop);
		if (!string.IsNullOrEmpty(SelectedCurrency))
			filtered = filtered.Where(p => p.CostType == SelectedCurrency);
		if (DateFrom.HasValue)
			filtered = filtered.Where(p => p.PurchasedAt >= DateFrom.Value);
		if (DateTo.HasValue)
			filtered = filtered.Where(p => p.PurchasedAt <= DateTo.Value.AddDays(1));

		FilteredPurchases = filtered.ToList();
	}

	private void ClearFilters() {
		SelectedShop = "";
		SelectedCurrency = "";
		DateFrom = null;
		DateTo = null;
		FilteredPurchases = AllPurchases;
	}

	/// <summary>Formats shop type to friendly display name.</summary>
	private static string FormatShopName(string shopType) {
		return shopType switch {
			"arena" => "Arena Shop",
			"guild" => "Guild Shop",
			"tower" => "Tower Shop",
			"merchant" => "Merchant",
			"outland" => "Outland Shop",
			"titan" => "Titan Shop",
			"event" => "Event Shop",
			"heroic" => "Heroic Shop",
			_ => shopType,
		};
	}

	/// <summary>Formats currency type to display name.</summary>
	private static string FormatCurrency(string currency) {
		return currency switch {
			"gold" => "Gold",
			"emeralds" => "Emeralds",
			"arena_coins" => "Arena Coins",
			"guild_coins" => "Guild Coins",
			"tower_coins" => "Tower Coins",
			"guild_war_coins" => "GW Coins",
			"titan_potion" => "Titan Potion",
			_ => currency,
		};
	}

	/// <summary>Returns badge class for shop type.</summary>
	private static string GetShopBadgeClass(string shopType) {
		return shopType switch {
			"arena" => "bg-primary",
			"guild" => "bg-secondary",
			"tower" => "bg-dark",
			"merchant" => "bg-success",
			"outland" => "bg-info",
			"titan" => "bg-danger",
			_ => "bg-secondary",
		};
	}

	/// <summary>Returns badge class for currency type.</summary>
	private static string GetCurrencyBadgeClass(string currency) {
		return currency switch {
			"gold" => "bg-warning text-dark",
			"emeralds" => "bg-success",
			"arena_coins" => "bg-primary",
			"guild_coins" => "bg-secondary",
			"tower_coins" => "bg-dark",
			_ => "bg-secondary",
		};
	}

	/// <summary>Summary row for shop type breakdown.</summary>
	private class ShopSummaryRow {
		public string ShopType { get; set; } = "";
		public int Count { get; set; }
		public long TotalCost { get; set; }
	}
}
