@page "/titans"
@using OrganizedJihad.Data
@using OrganizedJihad.Data.Models
@using Microsoft.EntityFrameworkCore
@using System.Text.Json
@inject IDbContextFactory<GameDatabaseContext> DbFactory

<PageTitle>Titan Roster - OrganizedJihad</PageTitle>

<div class="container-fluid">
	<div class="row mb-4">
		<div class="col-12">
			<h1 class="display-5">Titan Roster</h1>
			<p class="text-muted">Latest snapshot of all titans with element, progression, artifacts, skins, and totems.</p>
		</div>
	</div>

	@if (IsLoading) {
		<div class="row">
			<div class="col-12 text-center py-5">
				<div class="spinner-border" role="status">
					<span class="visually-hidden">Loading...</span>
				</div>
			</div>
		</div>
	} else if (!Titans.Any()) {
		<div class="row">
			<div class="col-12 text-center py-5 text-muted">
				<p class="mb-0">No titan data captured yet.</p>
				<small>Titan data will appear after the browser extension captures a titanGetAll API response.</small>
			</div>
		</div>
	} else {
		<!-- Summary Cards -->
		<div class="row mb-4">
			<div class="col-md-2">
				<div class="card text-center border-primary">
					<div class="card-body py-2">
						<div class="fs-4 fw-bold text-primary">@Titans.Count</div>
						<small class="text-muted">Titans</small>
					</div>
				</div>
			</div>
			<div class="col-md-2">
				<div class="card text-center">
					<div class="card-body py-2">
						<div class="fs-4 fw-bold">@Titans.Sum(t => t.Power).ToString("N0")</div>
						<small class="text-muted">Total Power</small>
					</div>
				</div>
			</div>
			<div class="col-md-2">
				<div class="card text-center">
					<div class="card-body py-2">
						<div class="fs-4 fw-bold">@(Titans.Any() ? Titans.Max(t => t.Level) : 0)</div>
						<small class="text-muted">Max Level</small>
					</div>
				</div>
			</div>
			<div class="col-md-2">
				<div class="card text-center">
					<div class="card-body py-2">
						<div class="fs-4 fw-bold">@Titans.Count(t => t.Stars >= 6)</div>
						<small class="text-muted">★6+ Titans</small>
					</div>
				</div>
			</div>
			<div class="col-md-4">
				<div class="card">
					<div class="card-body py-2">
						<small class="text-muted d-block">Snapshot from</small>
						<span>@SnapshotTime?.ToString("yyyy-MM-dd HH:mm:ss") ?? "N/A"</span>
					</div>
				</div>
			</div>
		</div>

		<!-- Element Summary -->
		<div class="row mb-4">
			@foreach (var elem in ElementGroups) {
				<div class="col">
					<div class="card text-center">
						<div class="card-body py-2">
							<span class="@GetElementBadgeClass(elem.Key) px-2 py-1 rounded mb-1 d-inline-block">
								@GetElementIcon(elem.Key) @elem.Key
							</span>
							<div class="fs-5 fw-bold">@elem.Value.ToString("N0")</div>
							<small class="text-muted">Power</small>
						</div>
					</div>
				</div>
			}
		</div>

		<!-- Sort / Filter Options -->
		<div class="row mb-3">
			<div class="col-md-3">
				<label class="form-label fw-bold">Sort by</label>
				<select class="form-select" @bind="SortField" @bind:after="ApplySort">
					<option value="power">Power (desc)</option>
					<option value="level">Level (desc)</option>
					<option value="stars">Stars (desc)</option>
					<option value="name">Name (A-Z)</option>
					<option value="element">Element</option>
					<option value="id">ID</option>
				</select>
			</div>
			<div class="col-md-3">
				<label class="form-label fw-bold">Element</label>
				<select class="form-select" @bind="SelectedElement" @bind:after="ApplySort">
					<option value="">All Elements</option>
					<option value="water">🌊 Water</option>
					<option value="fire">🔥 Fire</option>
					<option value="earth">🌿 Earth</option>
					<option value="dark">🌑 Dark</option>
					<option value="light">☀️ Light</option>
				</select>
			</div>
		</div>

		<!-- Titan Table -->
		<div class="row">
			<div class="col-12">
				<div class="card">
					<div class="card-header d-flex justify-content-between align-items-center">
						<h5 class="mb-0">All Titans</h5>
						<span class="badge bg-secondary">@FilteredTitans.Count titans</span>
					</div>
					<div class="card-body p-0">
						<div class="table-responsive">
							<table class="table table-striped table-hover mb-0 table-sm">
								<thead class="table-dark">
									<tr>
										<th class="text-end">ID</th>
										<th>Name</th>
										<th class="text-center">Element</th>
										<th>Level</th>
										<th>Stars</th>
										<th class="text-end">Power</th>
										<th>Skill</th>
										<th>Artifacts</th>
										<th>Skin</th>
										<th>Totems</th>
									</tr>
								</thead>
								<tbody>
									@foreach (var titan in FilteredTitans) {
										<tr>
											<td class="text-end text-muted">@titan.TitanId</td>
											<td><strong>@titan.DisplayName</strong></td>
											<td class="text-center">
												<span class="badge @GetElementBadgeClass(titan.Element)">
													@GetElementIcon(titan.Element) @titan.Element
												</span>
											</td>
											<td>
												<div class="d-flex align-items-center gap-1">
													<span style="min-width: 28px;" class="text-end">@titan.Level</span>
													<div class="progress flex-grow-1" style="height: 14px; min-width: 60px;" title="@titan.Level / @MaxTitanLevel (@(titan.Level * 100 / MaxTitanLevel)%)">
														<div class="progress-bar bg-info" style="width: @(titan.Level * 100 / MaxTitanLevel)%"></div>
													</div>
												</div>
											</td>
											<td>
												<div class="d-flex align-items-center gap-1">
													<span class="@GetStarClass(titan.Stars)" style="min-width: 20px;">
														★@titan.Stars
													</span>
													<div class="progress flex-grow-1" style="height: 14px; min-width: 50px;" title="@titan.Stars / @MaxTitanStars (@(titan.Stars * 100 / MaxTitanStars)%)">
														<div class="progress-bar bg-warning" style="width: @(titan.Stars * 100 / MaxTitanStars)%"></div>
													</div>
												</div>
											</td>
											<td class="text-end fw-bold">@titan.Power.ToString("N0")</td>
											<td>
												<div class="d-flex align-items-center gap-1" title="Skill Lv @titan.SkillLevel / @MaxTitanLevel (@(titan.SkillLevel * 100 / MaxTitanLevel)%)">
													<span style="min-width: 28px;" class="text-end">@titan.SkillLevel</span>
													<div class="progress flex-grow-1" style="height: 14px; min-width: 50px;">
														<div class="progress-bar bg-primary" style="width: @(titan.SkillLevel * 100 / MaxTitanLevel)%"></div>
													</div>
												</div>
											</td>
											<td>
												@if (!string.IsNullOrEmpty(titan.ArtifactSummary)) {
													<div class="d-flex align-items-center gap-1" title="@titan.ArtifactSummary (@(titan.ArtifactPct)%)">
														<small class="text-secondary" style="min-width: 50px;">@titan.ArtifactSummary</small>
														<div class="progress flex-grow-1" style="height: 14px; min-width: 30px;">
															<div class="progress-bar bg-danger" style="width: @(titan.ArtifactPct)%"></div>
														</div>
													</div>
												} else {
													<small class="text-muted">—</small>
												}
											</td>
											<td>
												<div class="d-flex align-items-center gap-1" title="Skin Lv @titan.SkinLevel / @MaxTitanSkinLevel (@(MaxTitanSkinLevel > 0 ? titan.SkinLevel * 100 / MaxTitanSkinLevel : 0)%)">
													<span style="min-width: 20px;" class="text-end">@titan.SkinLevel</span>
													<div class="progress flex-grow-1" style="height: 14px; min-width: 40px;">
														<div class="progress-bar bg-dark" style="width: @(MaxTitanSkinLevel > 0 ? titan.SkinLevel * 100 / MaxTitanSkinLevel : 0)%"></div>
													</div>
												</div>
											</td>
											<td>
												@if (!string.IsNullOrEmpty(titan.TotemSummary)) {
													<small class="text-info">@titan.TotemSummary</small>
												} else {
													<small class="text-muted">—</small>
												}
											</td>
										</tr>
									}
								</tbody>
							</table>
						</div>
					</div>
				</div>
			</div>
		</div>
	}
</div>

@code {
	private bool IsLoading { get; set; } = true;
	private List<TitanRow> Titans { get; set; } = new();
	private List<TitanRow> FilteredTitans { get; set; } = new();
	private DateTime? SnapshotTime { get; set; }
	private string SortField { get; set; } = "power";
	private string SelectedElement { get; set; } = "";
	private Dictionary<string, int> ElementGroups { get; set; } = new();

	// ── Max values for progress bar calculations ────────────────────
	private const int MaxTitanLevel = 120;
	private const int MaxTitanStars = 6;
	private const int MaxTitanArtifactLevel = 120;
	private const int MaxTitanSkinLevel = 60;

	protected override async Task OnInitializedAsync() {
		await LoadData();
		IsLoading = false;
	}

	private async Task LoadData() {
		using var context = await DbFactory.CreateDbContextAsync();

		// Get the latest snapshot timestamp
		var latestTimestamp = await context.Titans.AsNoTracking()
			.MaxAsync(t => (DateTime?)t.Timestamp);

		if (latestTimestamp == null) return;

		SnapshotTime = latestTimestamp;

		// Load all titans from the latest snapshot
		var titans = await context.Titans.AsNoTracking()
			.Where(t => t.Timestamp == latestTimestamp)
			.ToListAsync();

		Titans = titans.Select(t => {
			var element = !string.IsNullOrEmpty(t.Element) && t.Element != "titan" && t.Element != "unknown"
				? t.Element
				: HeroNames.ResolveTitanElement(t.TitanId);
			var (artSummary, artTotal, artCount) = ParseArtifactData(t.ArtifactData);
			return new TitanRow {
				TitanId = t.TitanId,
				DisplayName = HeroNames.ResolveWithFallback(t.TitanId, t.TitanName),
				Level = t.Level,
				Stars = t.Stars,
				Power = t.Power,
				Element = element,
				SkillLevel = t.SkillLevel,
				SkinLevel = t.SkinLevel,
				SummonStars = t.SummonStars,
				ArtifactSummary = artSummary,
				ArtifactTotalLevel = artTotal,
				ArtifactCount = artCount > 0 ? artCount : 1,
				TotemSummary = ParseTotemData(t.ArtifactData),
			};
		}).ToList();

		// Build element power summary
		ElementGroups = Titans
			.GroupBy(t => char.ToUpper(t.Element[0]) + t.Element[1..])
			.OrderBy(g => g.Key)
			.ToDictionary(g => g.Key, g => g.Sum(t => t.Power));

		ApplySort();
	}

	private void ApplySort() {
		var filtered = Titans.AsEnumerable();

		if (!string.IsNullOrEmpty(SelectedElement)) {
			filtered = filtered.Where(t => t.Element.Equals(SelectedElement, StringComparison.OrdinalIgnoreCase));
		}

		FilteredTitans = (SortField switch {
			"power" => filtered.OrderByDescending(t => t.Power),
			"level" => filtered.OrderByDescending(t => t.Level).ThenByDescending(t => t.Power),
			"stars" => filtered.OrderByDescending(t => t.Stars).ThenByDescending(t => t.Power),
			"name" => filtered.OrderBy(t => t.DisplayName),
			"element" => filtered.OrderBy(t => t.Element).ThenByDescending(t => t.Power),
			"id" => filtered.OrderBy(t => t.TitanId),
			_ => filtered.OrderByDescending(t => t.Power),
		}).ToList();
	}

	/// <summary>
	/// Parses the ArtifactData JSON to extract artifact level summary.
	/// Titan artifacts may be stored as a JSON object with artifact entries.
	/// Returns (summary string, total levels, artifact count).
	/// </summary>
	private static (string?, int, int) ParseArtifactData(string? artifactData) {
		if (string.IsNullOrEmpty(artifactData) || artifactData == "{}") return (null, 0, 0);

		try {
			using var doc = JsonDocument.Parse(artifactData);
			if (doc.RootElement.ValueKind == JsonValueKind.Object) {
				var parts = new List<string>();
				var total = 0;
				var count = 0;
				foreach (var prop in doc.RootElement.EnumerateObject()) {
					// Try to get a level from each artifact entry
					int level = 0;
					int stars = 0;
					if (prop.Value.ValueKind == JsonValueKind.Object) {
						if (prop.Value.TryGetProperty("level", out var lvl)) {
							level = lvl.TryGetInt32(out var v) ? v : 0;
						}
						if (prop.Value.TryGetProperty("star", out var st) || prop.Value.TryGetProperty("stars", out st)) {
							stars = st.TryGetInt32(out var s) ? s : 0;
						}
						parts.Add($"★{stars} Lv{level}");
					} else if (prop.Value.ValueKind == JsonValueKind.Number) {
						level = prop.Value.TryGetInt32(out var v) ? v : 0;
						parts.Add($"Lv{level}");
					}
					total += level;
					count++;
				}
				return (parts.Count > 0 ? string.Join(" ", parts) : null, total, count);
			}

			if (doc.RootElement.ValueKind == JsonValueKind.Array) {
				var parts = new List<string>();
				var total = 0;
				var count = 0;
				foreach (var el in doc.RootElement.EnumerateArray()) {
					if (el.ValueKind == JsonValueKind.Object) {
						int level = 0;
						int stars = 0;
						if (el.TryGetProperty("level", out var lvl)) {
							level = lvl.TryGetInt32(out var v) ? v : 0;
						}
						if (el.TryGetProperty("star", out var st) || el.TryGetProperty("stars", out st)) {
							stars = st.TryGetInt32(out var s) ? s : 0;
						}
						parts.Add($"★{stars} Lv{level}");
						total += level;
						count++;
					}
				}
				return (parts.Count > 0 ? string.Join(" ", parts) : null, total, count);
			}
		} catch {
			// JSON parsing failure — return empty
		}
		return (null, 0, 0);
	}

	/// <summary>
	/// Parses totem data from the artifact JSON if present.
	/// Totems may be embedded in the titan's artifact data as a separate section.
	/// </summary>
	private static string? ParseTotemData(string? artifactData) {
		if (string.IsNullOrEmpty(artifactData) || artifactData == "{}") return null;

		try {
			using var doc = JsonDocument.Parse(artifactData);
			if (doc.RootElement.ValueKind == JsonValueKind.Object) {
				// Look for totem-related properties
				if (doc.RootElement.TryGetProperty("totem", out var totem) ||
					doc.RootElement.TryGetProperty("totems", out totem)) {
					if (totem.ValueKind == JsonValueKind.Object) {
						var parts = new List<string>();
						foreach (var prop in totem.EnumerateObject()) {
							parts.Add($"{prop.Name}:{prop.Value}");
						}
						return parts.Count > 0 ? string.Join(" ", parts) : null;
					}
					if (totem.ValueKind == JsonValueKind.Number) {
						return $"Lv{totem.GetInt32()}";
					}
				}
			}
		} catch {
			// JSON parsing failure
		}
		return null;
	}

	/// <summary>
	/// Returns a CSS class for star display.
	/// </summary>
	private static string GetStarClass(int stars) => stars switch {
		>= 6 => "text-warning fw-bold",
		>= 4 => "text-warning",
		_ => "text-muted",
	};

	/// <summary>
	/// Returns a Bootstrap badge CSS class based on element type.
	/// </summary>
	private static string GetElementBadgeClass(string element) => element.ToLower() switch {
		"water" => "bg-primary",
		"fire" => "bg-danger",
		"earth" => "bg-success",
		"dark" => "bg-dark",
		"light" => "bg-warning text-dark",
		_ => "bg-secondary",
	};

	/// <summary>
	/// Returns an element icon emoji.
	/// </summary>
	private static string GetElementIcon(string element) => element.ToLower() switch {
		"water" => "🌊",
		"fire" => "🔥",
		"earth" => "🌿",
		"dark" => "🌑",
		"light" => "☀️",
		_ => "❓",
	};

	/// <summary>
	/// View model for displaying titan roster information.
	/// </summary>
	private class TitanRow {
		public long TitanId { get; set; }
		public string DisplayName { get; set; } = "";
		public int Level { get; set; }
		public int Stars { get; set; }
		public int Power { get; set; }
		public string Element { get; set; } = "unknown";
		public int SkillLevel { get; set; }
		public int SkinLevel { get; set; }
		public int SummonStars { get; set; }
		public string? ArtifactSummary { get; set; }
		public int ArtifactTotalLevel { get; set; }
		public int ArtifactCount { get; set; }
		/// <summary>Artifact completion percentage (0–100).</summary>
		public int ArtifactPct => ArtifactCount > 0
			? ArtifactTotalLevel * 100 / (120 * ArtifactCount)
			: 0;
		public string? TotemSummary { get; set; }
	}
}
