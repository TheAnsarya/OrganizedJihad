@page "/hero-upgrades"
@using OrganizedJihad.Data
@using OrganizedJihad.Data.Models
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<GameDatabaseContext> DbFactory

<PageTitle>Hero Upgrades - OrganizedJihad</PageTitle>

<div class="container-fluid">
	<div class="row mb-4">
		<div class="col-12">
			<h1 class="display-5">Hero Upgrade Timeline</h1>
			<p class="text-muted">Track hero level, star, color, skill, artifact, glyph, and skin upgrades over time.</p>
		</div>
	</div>

	<!-- Filters -->
	<div class="row mb-4">
		<div class="col-md-3">
			<label class="form-label fw-bold">Hero</label>
			<select class="form-select" @bind="SelectedHeroName">
				<option value="">All Heroes</option>
				@foreach (var name in HeroNameList) {
					<option value="@name">@name</option>
				}
			</select>
		</div>
		<div class="col-md-2">
			<label class="form-label fw-bold">Upgrade Type</label>
			<select class="form-select" @bind="SelectedUpgradeType">
				<option value="">All Types</option>
				<option value="level">Level</option>
				<option value="star">Star</option>
				<option value="color">Color</option>
				<option value="skill">Skill</option>
				<option value="artifact">Artifact</option>
				<option value="glyph">Glyph</option>
				<option value="skin">Skin</option>
			</select>
		</div>
		<div class="col-md-2">
			<label class="form-label fw-bold">From</label>
			<input type="date" class="form-control" @bind="DateFrom" />
		</div>
		<div class="col-md-2">
			<label class="form-label fw-bold">To</label>
			<input type="date" class="form-control" @bind="DateTo" />
		</div>
		<div class="col-md-3 d-flex align-items-end">
			<button class="btn btn-primary me-2" @onclick="ApplyFilters">Apply</button>
			<button class="btn btn-outline-secondary" @onclick="ClearFilters">Clear</button>
		</div>
	</div>

	@if (IsLoading) {
		<div class="row">
			<div class="col-12 text-center py-5">
				<div class="spinner-border" role="status">
					<span class="visually-hidden">Loading...</span>
				</div>
			</div>
		</div>
	} else {
		<!-- Summary Cards -->
		<div class="row mb-4">
			<div class="col-md-2">
				<div class="card text-center border-primary">
					<div class="card-body py-2">
						<div class="fs-4 fw-bold text-primary">@TotalUpgrades</div>
						<small class="text-muted">Total</small>
					</div>
				</div>
			</div>
			<div class="col-md-2">
				<div class="card text-center">
					<div class="card-body py-2">
						<div class="fs-4 fw-bold">@LevelCount</div>
						<small class="text-muted">Levels</small>
					</div>
				</div>
			</div>
			<div class="col-md-2">
				<div class="card text-center">
					<div class="card-body py-2">
						<div class="fs-4 fw-bold">@SkillCount</div>
						<small class="text-muted">Skills</small>
					</div>
				</div>
			</div>
			<div class="col-md-2">
				<div class="card text-center">
					<div class="card-body py-2">
						<div class="fs-4 fw-bold">@ArtifactCount</div>
						<small class="text-muted">Artifacts</small>
					</div>
				</div>
			</div>
			<div class="col-md-2">
				<div class="card text-center">
					<div class="card-body py-2">
						<div class="fs-4 fw-bold">@GlyphCount</div>
						<small class="text-muted">Glyphs</small>
					</div>
				</div>
			</div>
			<div class="col-md-2">
				<div class="card text-center">
					<div class="card-body py-2">
						<div class="fs-4 fw-bold">@(StarCount + ColorCount + SkinCount)</div>
						<small class="text-muted">Star/Color/Skin</small>
					</div>
				</div>
			</div>
		</div>

		<!-- Upgrade Timeline Table -->
		<div class="row">
			<div class="col-12">
				<div class="card">
					<div class="card-header d-flex justify-content-between align-items-center">
						<h5 class="mb-0">Upgrade Events</h5>
						<span class="badge bg-secondary">@FilteredUpgrades.Count records</span>
					</div>
					<div class="card-body p-0">
						@if (FilteredUpgrades.Any()) {
							<div class="table-responsive">
								<table class="table table-striped table-hover mb-0">
									<thead class="table-dark">
										<tr>
											<th>Time</th>
											<th class="text-end">ID</th>
											<th>Hero</th>
											<th>Type</th>
											<th>Details</th>
											<th>Artifact</th>
											<th>Glyph</th>
											<th>Ascension</th>
											<th class="text-end">Power</th>
										</tr>
									</thead>
									<tbody>
										@foreach (var upgrade in FilteredUpgrades.Take(200)) {
											<tr>
												<td>
													<small>@upgrade.Timestamp.ToString("MMM dd HH:mm")</small>
												</td>
												<td class="text-end text-muted">
													<small>@upgrade.HeroId</small>
												</td>
												<td>
													<strong>@upgrade.DisplayName</strong>
												</td>
												<td>
													<span class="badge @GetUpgradeTypeBadgeClass(upgrade.UpgradeType)">
														@upgrade.UpgradeType
													</span>
												</td>
												<td>@upgrade.Details</td>
												<td>
													@if (!string.IsNullOrEmpty(upgrade.ArtifactInfo)) {
														<small class="text-info">@upgrade.ArtifactInfo</small>
													}
												</td>
												<td>
													@if (!string.IsNullOrEmpty(upgrade.GlyphInfo)) {
														<small class="text-secondary">@upgrade.GlyphInfo</small>
													}
												</td>
												<td>
													@if (!string.IsNullOrEmpty(upgrade.AscensionInfo)) {
														<small class="text-warning">@upgrade.AscensionInfo</small>
													}
												</td>
												<td class="text-end">
													@if (upgrade.PowerAfter > 0) {
														<span class="text-muted">@upgrade.PowerAfter.ToString("N0")</span>
													}
												</td>
											</tr>
										}
									</tbody>
								</table>
							</div>
							@if (FilteredUpgrades.Count > 200) {
								<div class="text-center py-2 text-muted">
									<small>Showing first 200 of @FilteredUpgrades.Count records</small>
								</div>
							}
						} else {
							<div class="text-center py-5 text-muted">
								<p class="mb-0">No hero upgrade events recorded yet.</p>
								<small>Upgrade data will appear after syncing from the browser extension.</small>
							</div>
						}
					</div>
				</div>
			</div>
		</div>
	}
</div>

@code {
	private bool IsLoading { get; set; } = true;
	private string SelectedHeroName { get; set; } = "";
	private string SelectedUpgradeType { get; set; } = "";
	private DateTime? DateFrom { get; set; }
	private DateTime? DateTo { get; set; }
	private List<string> HeroNameList { get; set; } = new();
	private List<UpgradeRow> AllUpgrades { get; set; } = new();
	private List<UpgradeRow> FilteredUpgrades { get; set; } = new();

	// Summary counts
	private int TotalUpgrades => FilteredUpgrades.Count;
	private int LevelCount => FilteredUpgrades.Count(u => u.UpgradeType == "Level");
	private int StarCount => FilteredUpgrades.Count(u => u.UpgradeType == "Star");
	private int ColorCount => FilteredUpgrades.Count(u => u.UpgradeType == "Color");
	private int SkillCount => FilteredUpgrades.Count(u => u.UpgradeType == "Skill");
	private int ArtifactCount => FilteredUpgrades.Count(u => u.UpgradeType == "Artifact");
	private int GlyphCount => FilteredUpgrades.Count(u => u.UpgradeType == "Glyph");
	private int SkinCount => FilteredUpgrades.Count(u => u.UpgradeType == "Skin");

	protected override async Task OnInitializedAsync() {
		await LoadData();
		IsLoading = false;
	}

	/// <summary>
	/// Resolves a hero name from the static dictionary, falling back to
	/// the stored name only if it's a real name (not Hero_NNN).
	/// </summary>
	private static string ResolveName(long heroId, string storedName) =>
		HeroNames.ResolveWithFallback(heroId, storedName);

	private async Task LoadData() {
		using var context = await DbFactory.CreateDbContextAsync();

		// Load all upgrade types and unify into a single timeline
		var levels = await context.HeroLevelUpgrades.AsNoTracking()
			.OrderByDescending(u => u.Timestamp)
			.ToListAsync();
		var stars = await context.HeroStarUpgrades.AsNoTracking()
			.OrderByDescending(u => u.Timestamp)
			.ToListAsync();
		var colors = await context.HeroColorUpgrades.AsNoTracking()
			.OrderByDescending(u => u.Timestamp)
			.ToListAsync();
		var skills = await context.HeroSkillUpgrades.AsNoTracking()
			.OrderByDescending(u => u.Timestamp)
			.ToListAsync();
		var artifacts = await context.HeroArtifactUpgrades.AsNoTracking()
			.OrderByDescending(u => u.Timestamp)
			.ToListAsync();
		var glyphs = await context.HeroGlyphUpgrades.AsNoTracking()
			.OrderByDescending(u => u.Timestamp)
			.ToListAsync();
		var skins = await context.HeroSkinUpgrades.AsNoTracking()
			.OrderByDescending(u => u.Timestamp)
			.ToListAsync();

		// Combine into unified rows
		AllUpgrades = new List<UpgradeRow>();

		AllUpgrades.AddRange(levels.Select(u => new UpgradeRow {
			Timestamp = u.Timestamp,
			HeroId = u.HeroId,
			DisplayName = ResolveName(u.HeroId, u.HeroName),
			UpgradeType = "Level",
			Details = $"Lv {u.LevelBefore} → {u.LevelAfter} ({u.ExperienceSpent:N0} XP, {u.GoldSpent:N0} gold)",
			PowerAfter = u.PowerAfter,
		}));

		AllUpgrades.AddRange(stars.Select(u => new UpgradeRow {
			Timestamp = u.Timestamp,
			HeroId = u.HeroId,
			DisplayName = ResolveName(u.HeroId, u.HeroName),
			UpgradeType = "Star",
			Details = $"★{u.StarsBefore} → ★{u.StarsAfter} ({u.SoulStonesConsumed} soul stones)",
			PowerAfter = u.PowerAfter,
		}));

		AllUpgrades.AddRange(colors.Select(u => new UpgradeRow {
			Timestamp = u.Timestamp,
			HeroId = u.HeroId,
			DisplayName = ResolveName(u.HeroId, u.HeroName),
			UpgradeType = "Color",
			Details = $"{u.ColorNameBefore ?? $"Rank {u.ColorBefore}"} → {u.ColorNameAfter ?? $"Rank {u.ColorAfter}"}",
			PowerAfter = u.PowerAfter,
		}));

		AllUpgrades.AddRange(skills.Select(u => new UpgradeRow {
			Timestamp = u.Timestamp,
			HeroId = u.HeroId,
			DisplayName = ResolveName(u.HeroId, u.HeroName),
			UpgradeType = "Skill",
			Details = $"{u.SkillName} Lv {u.SkillLevelBefore} → {u.SkillLevelAfter} ({u.GoldSpent:N0} gold)",
			PowerAfter = u.PowerAfter,
		}));

		AllUpgrades.AddRange(artifacts.Select(u => new UpgradeRow {
			Timestamp = u.Timestamp,
			HeroId = u.HeroId,
			DisplayName = ResolveName(u.HeroId, u.HeroName),
			UpgradeType = "Artifact",
			Details = $"{u.ArtifactType} {u.ArtifactName ?? ""} Lv {u.LevelBefore} → {u.LevelAfter}",
			ArtifactInfo = $"{u.ArtifactType}: {u.ArtifactName ?? "?"} Lv {u.LevelAfter}",
			PowerAfter = u.PowerAfter,
		}));

		AllUpgrades.AddRange(glyphs.Select(u => new UpgradeRow {
			Timestamp = u.Timestamp,
			HeroId = u.HeroId,
			DisplayName = ResolveName(u.HeroId, u.HeroName),
			UpgradeType = "Glyph",
			Details = $"{u.GlyphType} Lv {u.GlyphLevelBefore} → {u.GlyphLevelAfter} ({u.GoldSpent:N0} gold)",
			GlyphInfo = $"{u.GlyphType}: Lv {u.GlyphLevelAfter}",
			PowerAfter = u.PowerAfter,
		}));

		AllUpgrades.AddRange(skins.Select(u => new UpgradeRow {
			Timestamp = u.Timestamp,
			HeroId = u.HeroId,
			DisplayName = ResolveName(u.HeroId, u.HeroName),
			UpgradeType = "Skin",
			Details = u.IsNewUnlock
				? $"{u.SkinName} unlocked!"
				: $"{u.SkinName} Lv {u.LevelBefore} → {u.LevelAfter} ({u.SkinStonesConsumed} stones)",
			PowerAfter = u.PowerAfter,
		}));

		// Sort by timestamp descending
		AllUpgrades = AllUpgrades.OrderByDescending(u => u.Timestamp).ToList();

		// Extract unique hero names for filter dropdown (using resolved names)
		HeroNameList = AllUpgrades.Select(u => u.DisplayName)
			.Where(n => !string.IsNullOrEmpty(n))
			.Distinct()
			.OrderBy(n => n)
			.ToList();

		ApplyFilters();
	}

	private void ApplyFilters() {
		var filtered = AllUpgrades.AsEnumerable();

		if (!string.IsNullOrEmpty(SelectedHeroName)) {
			filtered = filtered.Where(u => u.DisplayName == SelectedHeroName);
		}

		if (!string.IsNullOrEmpty(SelectedUpgradeType)) {
			var type = SelectedUpgradeType[..1].ToUpper() + SelectedUpgradeType[1..].ToLower();
			filtered = filtered.Where(u => u.UpgradeType == type);
		}

		if (DateFrom.HasValue) {
			filtered = filtered.Where(u => u.Timestamp >= DateFrom.Value);
		}

		if (DateTo.HasValue) {
			filtered = filtered.Where(u => u.Timestamp <= DateTo.Value.AddDays(1));
		}

		FilteredUpgrades = filtered.ToList();
	}

	private void ClearFilters() {
		SelectedHeroName = "";
		SelectedUpgradeType = "";
		DateFrom = null;
		DateTo = null;
		FilteredUpgrades = AllUpgrades;
	}

	/// <summary>
	/// Returns a Bootstrap badge CSS class based on upgrade type for visual differentiation.
	/// </summary>
	private static string GetUpgradeTypeBadgeClass(string upgradeType) => upgradeType switch {
		"Level" => "bg-info",
		"Star" => "bg-warning text-dark",
		"Color" => "bg-success",
		"Skill" => "bg-primary",
		"Artifact" => "bg-danger",
		"Glyph" => "bg-secondary",
		"Skin" => "bg-dark",
		_ => "bg-secondary",
	};

	/// <summary>
	/// Unified view model for displaying all hero upgrade types in a single table.
	/// Includes optional columns for artifact, glyph, and ascension details.
	/// </summary>
	private class UpgradeRow {
		/// <summary>When the upgrade occurred.</summary>
		public DateTime Timestamp { get; set; }

		/// <summary>Game's internal hero ID (e.g. 49 = Yasmine).</summary>
		public long HeroId { get; set; }

		/// <summary>Resolved display name (from static dictionary).</summary>
		public string DisplayName { get; set; } = "";

		/// <summary>Type of upgrade (Level, Star, Color, Skill, Artifact, Glyph, Skin).</summary>
		public string UpgradeType { get; set; } = "";

		/// <summary>Human-readable details of the upgrade.</summary>
		public string Details { get; set; } = "";

		/// <summary>Artifact-specific info (only for artifact upgrades).</summary>
		public string? ArtifactInfo { get; set; }

		/// <summary>Glyph-specific info (only for glyph upgrades).</summary>
		public string? GlyphInfo { get; set; }

		/// <summary>Ascension-specific info (only for ascension-related upgrades).</summary>
		public string? AscensionInfo { get; set; }

		/// <summary>Hero's total power after the upgrade.</summary>
		public int PowerAfter { get; set; }
	}
}
