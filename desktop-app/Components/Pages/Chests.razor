@page "/chests"
@using OrganizedJihad.Data
@using OrganizedJihad.Data.Models
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<GameDatabaseContext> DbFactory

<PageTitle>Chests - OrganizedJihad</PageTitle>

<div class="container-fluid">
	<div class="row mb-4">
		<div class="col-12">
			<h1 class="display-5">Chest Analytics</h1>
			<p class="text-muted">Track every chest opened, view items received, and analyze drop rates.</p>
		</div>
	</div>

	@if (IsLoading) {
		<div class="row">
			<div class="col-12 text-center py-5">
				<div class="spinner-border" role="status">
					<span class="visually-hidden">Loading...</span>
				</div>
			</div>
		</div>
	} else {
		<!-- Summary Cards -->
		<div class="row mb-4">
			<div class="col-md-3">
				<div class="card text-white bg-warning">
					<div class="card-body py-2">
						<h6 class="card-title mb-0">Total Chests Opened</h6>
						<p class="card-text display-6 mb-0">@AllChests.Count</p>
					</div>
				</div>
			</div>
			<div class="col-md-3">
				<div class="card text-white bg-info">
					<div class="card-body py-2">
						<h6 class="card-title mb-0">Total Items Received</h6>
						<p class="card-text display-6 mb-0">@TotalDrops</p>
					</div>
				</div>
			</div>
			<div class="col-md-3">
				<div class="card text-white bg-success">
					<div class="card-body py-2">
						<h6 class="card-title mb-0">Chest Types</h6>
						<p class="card-text display-6 mb-0">@ChestTypeSummary.Count</p>
					</div>
				</div>
			</div>
			<div class="col-md-3">
				<div class="card text-white bg-primary">
					<div class="card-body py-2">
						<h6 class="card-title mb-0">Avg Items/Chest</h6>
						<p class="card-text display-6 mb-0">@AvgDropsPerChest.ToString("F1")</p>
					</div>
				</div>
			</div>
		</div>

		<!-- Chest Type Filter -->
		<div class="row mb-3">
			<div class="col-md-3">
				<select class="form-select" @bind="SelectedType">
					<option value="">All Chest Types</option>
					@foreach (var t in ChestTypeSummary) {
						<option value="@t.Type">@FormatChestName(t.Type) (@t.Count)</option>
					}
				</select>
			</div>
			<div class="col-md-2">
				<input type="date" class="form-control" @bind="DateFrom" />
			</div>
			<div class="col-md-2">
				<input type="date" class="form-control" @bind="DateTo" />
			</div>
			<div class="col-md-3 d-flex align-items-end">
				<button class="btn btn-primary me-2" @onclick="ApplyFilters">Apply</button>
				<button class="btn btn-outline-secondary" @onclick="ClearFilters">Clear</button>
			</div>
		</div>

		<!-- Drop Rate Summary by Type -->
		@if (ChestTypeSummary.Any()) {
			<div class="row mb-4">
				<div class="col-md-6">
					<div class="card">
						<div class="card-header">
							<h5 class="mb-0">Chests by Type</h5>
						</div>
						<div class="card-body">
							@foreach (var ct in ChestTypeSummary) {
								var pct = AllChests.Count > 0 ? (int)((ct.Count / (double)AllChests.Count) * 100) : 0;
								<div class="mb-2">
									<div class="d-flex justify-content-between">
										<span class="fw-bold">@FormatChestName(ct.Type)</span>
										<span class="text-muted">@ct.Count opened (@ct.TotalDrops items)</span>
									</div>
									<div class="progress" style="height: 8px;">
										<div class="progress-bar bg-warning" role="progressbar"
											 style="width: @(pct)%"></div>
									</div>
								</div>
							}
						</div>
					</div>
				</div>

				<!-- Item Rarity Breakdown -->
				@if (RarityBreakdown.Any()) {
					<div class="col-md-6">
						<div class="card">
							<div class="card-header">
								<h5 class="mb-0">Drop Rarity Distribution</h5>
							</div>
							<div class="card-body">
								@foreach (var rb in RarityBreakdown) {
									var pct = TotalDrops > 0 ? (rb.Count / (double)TotalDrops) * 100 : 0;
									<div class="mb-2">
										<div class="d-flex justify-content-between">
											<span class="fw-bold">
												<span class="badge @GetRarityBadgeClass(rb.Rarity)">@(rb.Rarity ?? "unknown")</span>
											</span>
											<span class="text-muted">@rb.Count items (@pct.ToString("F1")%)</span>
										</div>
										<div class="progress" style="height: 8px;">
											<div class="progress-bar @GetRarityBarClass(rb.Rarity)" role="progressbar"
												 style="width: @((int)pct)%"></div>
										</div>
									</div>
								}
							</div>
						</div>
					</div>
				}
			</div>
		}

		<!-- Individual Chest Openings (Expanded) -->
		<div class="row">
			<div class="col-12">
				<div class="card">
					<div class="card-header d-flex justify-content-between align-items-center">
						<h5 class="mb-0">Chest Opening Log</h5>
						<span class="badge bg-secondary">@FilteredChests.Count records</span>
					</div>
					<div class="card-body p-0">
						@if (FilteredChests.Any()) {
							<div class="accordion" id="chestAccordion">
								@foreach (var chest in FilteredChests.Take(100)) {
									var collapseId = $"collapse-{chest.Id}";
									var headingId = $"heading-{chest.Id}";
									<div class="accordion-item">
										<h2 class="accordion-header" id="@headingId">
											<button class="accordion-button collapsed" type="button"
													data-bs-toggle="collapse" data-bs-target="#@collapseId">
												<div class="d-flex justify-content-between w-100 me-3">
													<div>
														<span class="badge bg-warning text-dark me-2">@FormatChestName(chest.ChestType)</span>
														<small class="text-muted">@chest.Timestamp.ToString("MMM dd, yyyy HH:mm")</small>
													</div>
													<div>
														@if (!string.IsNullOrEmpty(chest.OpenMethod)) {
															<span class="badge bg-secondary me-1">@chest.OpenMethod</span>
														}
														<span class="badge bg-info">@chest.Drops.Count items</span>
														@if (chest.Quantity > 1) {
															<span class="badge bg-primary">x@chest.Quantity</span>
														}
													</div>
												</div>
											</button>
										</h2>
										<div id="@collapseId" class="accordion-collapse collapse"
											 data-bs-parent="#chestAccordion">
											<div class="accordion-body p-0">
												@if (chest.Drops.Any()) {
													<table class="table table-sm table-striped mb-0">
														<thead class="table-light">
															<tr>
																<th>Item</th>
																<th>Type</th>
																<th>Rarity</th>
																<th class="text-end">Qty</th>
																<th class="text-end">% of Drops</th>
															</tr>
														</thead>
														<tbody>
															@{
																var totalQty = chest.Drops.Sum(d => d.Quantity);
															}
															@foreach (var drop in chest.Drops.OrderByDescending(d => d.Quantity)) {
																var dropPct = totalQty > 0 ? (drop.Quantity / (double)totalQty) * 100 : 0;
																<tr>
																	<td><strong>@drop.ItemName</strong></td>
																	<td><small class="text-muted">@(drop.ItemType ?? "—")</small></td>
																	<td>
																		<span class="badge @GetRarityBadgeClass(drop.Rarity)">
																			@(drop.Rarity ?? "—")
																		</span>
																	</td>
																	<td class="text-end">@drop.Quantity</td>
																	<td class="text-end">
																		<div class="d-flex align-items-center justify-content-end gap-1">
																			<div class="progress" style="width: 60px; height: 6px;">
																				<div class="progress-bar" style="width: @((int)dropPct)%"></div>
																			</div>
																			<small>@dropPct.ToString("F1")%</small>
																		</div>
																	</td>
																</tr>
															}
														</tbody>
													</table>
												} else {
													<div class="p-3 text-muted">No drop data recorded for this chest.</div>
												}
											</div>
										</div>
									</div>
								}
							</div>
							@if (FilteredChests.Count > 100) {
								<div class="text-center py-2 text-muted">
									<small>Showing first 100 of @FilteredChests.Count chests</small>
								</div>
							}
						} else {
							<div class="text-center py-5 text-muted">
								<p class="mb-0">No chest data recorded yet.</p>
								<small>Chest data will appear after syncing from the browser extension.</small>
							</div>
						}
					</div>
				</div>
			</div>
		</div>
	}
</div>

@code {
	private bool IsLoading { get; set; } = true;
	private string SelectedType { get; set; } = "";
	private DateTime? DateFrom { get; set; }
	private DateTime? DateTo { get; set; }

	private List<ChestOpening> AllChests { get; set; } = new();
	private List<ChestOpening> FilteredChests { get; set; } = new();
	private List<ChestTypeSummaryRow> ChestTypeSummary { get; set; } = new();
	private List<RarityRow> RarityBreakdown { get; set; } = new();
	private int TotalDrops { get; set; }
	private double AvgDropsPerChest { get; set; }

	protected override async Task OnInitializedAsync() {
		await LoadData();
		IsLoading = false;
	}

	private async Task LoadData() {
		using var context = await DbFactory.CreateDbContextAsync();

		AllChests = await context.ChestOpenings
			.Include(c => c.Drops)
			.AsNoTracking()
			.OrderByDescending(c => c.Timestamp)
			.ToListAsync();

		TotalDrops = AllChests.SelectMany(c => c.Drops).Sum(d => d.Quantity);
		AvgDropsPerChest = AllChests.Count > 0 ? TotalDrops / (double)AllChests.Count : 0;

		// Build type summary
		ChestTypeSummary = AllChests
			.GroupBy(c => c.ChestType)
			.Select(g => new ChestTypeSummaryRow {
				Type = g.Key,
				Count = g.Count(),
				TotalDrops = g.SelectMany(c => c.Drops).Sum(d => d.Quantity),
			})
			.OrderByDescending(s => s.Count)
			.ToList();

		// Build rarity breakdown from all drops
		RarityBreakdown = AllChests
			.SelectMany(c => c.Drops)
			.GroupBy(d => d.Rarity ?? "unknown")
			.Select(g => new RarityRow {
				Rarity = g.Key,
				Count = g.Sum(d => d.Quantity),
			})
			.OrderByDescending(r => r.Count)
			.ToList();

		ApplyFilters();
	}

	private void ApplyFilters() {
		var filtered = AllChests.AsEnumerable();

		if (!string.IsNullOrEmpty(SelectedType))
			filtered = filtered.Where(c => c.ChestType == SelectedType);
		if (DateFrom.HasValue)
			filtered = filtered.Where(c => c.Timestamp >= DateFrom.Value);
		if (DateTo.HasValue)
			filtered = filtered.Where(c => c.Timestamp <= DateTo.Value.AddDays(1));

		FilteredChests = filtered.ToList();
	}

	private void ClearFilters() {
		SelectedType = "";
		DateFrom = null;
		DateTo = null;
		FilteredChests = AllChests;
	}

	/// <summary>
	/// Formats raw chest type strings into friendly display names.
	/// e.g. "heroic" → "Heroic Chest", "titanArtifactChest" → "Titan Artifact Chest"
	/// </summary>
	private static string FormatChestName(string chestType) {
		return chestType switch {
			"heroic" => "Heroic Chest",
			"gold" => "Gold Chest",
			"titan" => "Titan Chest",
			"artifact" => "Artifact Chest",
			"artifactChest" => "Artifact Chest",
			"titanArtifactChest" => "Titan Artifact Chest",
			"petChest" => "Pet Chest",
			"lootBox" => "Loot Box",
			"towerChest" => "Tower Chest",
			"outlandChest" => "Outland Chest",
			"event" => "Event Chest",
			"skin" => "Skin Chest",
			"keys" => "Key Chest",
			_ => FormatCamelCase(chestType),
		};
	}

	/// <summary>
	/// Converts a camelCase or snake_case string to Title Case.
	/// </summary>
	private static string FormatCamelCase(string input) {
		if (string.IsNullOrEmpty(input)) return input;
		var result = System.Text.RegularExpressions.Regex.Replace(input, "([a-z])([A-Z])", "$1 $2");
		result = result.Replace('_', ' ');
		return System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(result);
	}

	/// <summary>
	/// Returns Bootstrap badge class for item rarity.
	/// </summary>
	private static string GetRarityBadgeClass(string? rarity) {
		return (rarity ?? "").ToLowerInvariant() switch {
			"common" => "bg-secondary",
			"uncommon" => "bg-success",
			"rare" => "bg-primary",
			"epic" => "bg-info",
			"legendary" => "bg-warning text-dark",
			_ => "bg-secondary",
		};
	}

	/// <summary>
	/// Returns Bootstrap progress bar class for item rarity.
	/// </summary>
	private static string GetRarityBarClass(string? rarity) {
		return (rarity ?? "").ToLowerInvariant() switch {
			"common" => "bg-secondary",
			"uncommon" => "bg-success",
			"rare" => "bg-primary",
			"epic" => "bg-info",
			"legendary" => "bg-warning",
			_ => "bg-secondary",
		};
	}

	/// <summary>Summary of chest openings by type.</summary>
	private class ChestTypeSummaryRow {
		public string Type { get; set; } = "";
		public int Count { get; set; }
		public int TotalDrops { get; set; }
	}

	/// <summary>Summary of drops by rarity.</summary>
	private class RarityRow {
		public string Rarity { get; set; } = "";
		public int Count { get; set; }
	}
}
