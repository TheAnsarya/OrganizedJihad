@page "/daily-activity"
@using OrganizedJihad.Data
@using OrganizedJihad.Data.Models
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<GameDatabaseContext> DbFactory

<PageTitle>Daily Activity - OrganizedJihad</PageTitle>

<div class="container-fluid">
	<div class="row mb-4">
		<div class="col-12">
			<h1 class="display-5">Daily Activity Dashboard</h1>
			<p class="text-muted">Quest completions, login rewards, and daily activity summaries.</p>
		</div>
	</div>

	<!-- Date Filter -->
	<div class="row mb-4">
		<div class="col-md-2">
			<label class="form-label fw-bold">From</label>
			<input type="date" class="form-control" @bind="DateFrom" />
		</div>
		<div class="col-md-2">
			<label class="form-label fw-bold">To</label>
			<input type="date" class="form-control" @bind="DateTo" />
		</div>
		<div class="col-md-2">
			<label class="form-label fw-bold">View</label>
			<select class="form-select" @bind="SelectedView">
				<option value="all">All Activity</option>
				<option value="daily">Daily Quests</option>
				<option value="guild">Guild Quests</option>
				<option value="login">Login Rewards</option>
			</select>
		</div>
		<div class="col-md-3 d-flex align-items-end">
			<button class="btn btn-primary me-2" @onclick="ApplyFilters">Apply</button>
			<button class="btn btn-outline-secondary" @onclick="ClearFilters">Clear</button>
		</div>
	</div>

	@if (IsLoading) {
		<div class="row">
			<div class="col-12 text-center py-5">
				<div class="spinner-border" role="status">
					<span class="visually-hidden">Loading...</span>
				</div>
			</div>
		</div>
	} else {
		<!-- Summary Cards -->
		<div class="row mb-4">
			<div class="col-md-3">
				<div class="card text-white bg-primary">
					<div class="card-body">
						<h5 class="card-title">Daily Quests</h5>
						<p class="card-text display-6">@DailyQuestCount</p>
						<small>Total completions</small>
					</div>
				</div>
			</div>
			<div class="col-md-3">
				<div class="card text-white bg-success">
					<div class="card-body">
						<h5 class="card-title">Guild Quests</h5>
						<p class="card-text display-6">@GuildQuestCount</p>
						<small>Total completions</small>
					</div>
				</div>
			</div>
			<div class="col-md-3">
				<div class="card text-white bg-info">
					<div class="card-body">
						<h5 class="card-title">Login Rewards</h5>
						<p class="card-text display-6">@LoginRewardCount</p>
						<small>Days claimed</small>
					</div>
				</div>
			</div>
			<div class="col-md-3">
				<div class="card text-white bg-warning">
					<div class="card-body">
						<h5 class="card-title">Activity Points</h5>
						<p class="card-text display-6">@TotalActivityPoints.ToString("N0")</p>
						<small>Total earned</small>
					</div>
				</div>
			</div>
		</div>

		<!-- Activity by Day Bar Chart (CSS-based) -->
		@if (DailyBreakdown.Any()) {
			<div class="row mb-4">
				<div class="col-12">
					<div class="card">
						<div class="card-header">
							<h5 class="mb-0">Quests Completed by Day</h5>
						</div>
						<div class="card-body">
							<div class="d-flex align-items-end gap-1" style="height: 200px; overflow-x: auto;">
								@foreach (var day in DailyBreakdown.TakeLast(30)) {
									var barHeight = MaxDailyCount > 0
										? (int)((day.Count / (double)MaxDailyCount) * 180)
										: 0;
									<div class="d-flex flex-column align-items-center" style="min-width: 28px;">
										<small class="text-muted mb-1" style="font-size: 0.65rem;">@day.Count</small>
										<div class="bg-primary rounded-top"
											 style="width: 20px; height: @(barHeight)px; min-height: 2px;"
											 title="@day.Date.ToString("MMM dd"): @day.Count quests">
										</div>
										<small class="text-muted mt-1" style="font-size: 0.6rem; writing-mode: vertical-rl;">
											@day.Date.ToString("M/d")
										</small>
									</div>
								}
							</div>
						</div>
					</div>
				</div>
			</div>
		}

		<!-- Login Streak Info -->
		@if (LatestLogin != null) {
			<div class="row mb-4">
				<div class="col-md-6">
					<div class="card">
						<div class="card-header">
							<h5 class="mb-0">Login Streak</h5>
						</div>
						<div class="card-body">
							<div class="row text-center">
								<div class="col-4">
									<div class="fs-3 fw-bold text-primary">@LatestLogin.DayNumber</div>
									<small class="text-muted">Current Day</small>
								</div>
								<div class="col-4">
									<div class="fs-3 fw-bold text-success">@LatestLogin.StreakLength</div>
									<small class="text-muted">Streak</small>
								</div>
								<div class="col-4">
									<div class="fs-3 fw-bold @(LatestLogin.IsVipBonus ? "text-warning" : "text-muted")">
										@(LatestLogin.IsVipBonus ? "VIP" : "Standard")
									</div>
									<small class="text-muted">Bonus Type</small>
								</div>
							</div>
							<hr />
							<small class="text-muted">Last claimed: @LatestLogin.ClaimedAt.ToString("MMM dd, yyyy HH:mm")</small>
						</div>
					</div>
				</div>
			</div>
		}

		<!-- Activity Log Table -->
		<div class="row">
			<div class="col-12">
				<div class="card">
					<div class="card-header d-flex justify-content-between align-items-center">
						<h5 class="mb-0">Activity Log</h5>
						<span class="badge bg-secondary">@FilteredActivities.Count records</span>
					</div>
					<div class="card-body p-0">
						@if (FilteredActivities.Any()) {
							<div class="table-responsive">
								<table class="table table-striped table-hover mb-0">
									<thead class="table-dark">
										<tr>
											<th>Time</th>
											<th>Type</th>
											<th>Name</th>
											<th>Details</th>
											<th class="text-end">Points</th>
										</tr>
									</thead>
									<tbody>
										@foreach (var activity in FilteredActivities.Take(200)) {
											<tr>
												<td><small>@activity.Timestamp.ToString("MMM dd HH:mm")</small></td>
												<td>
													<span class="badge @GetActivityBadgeClass(activity.ActivityType)">
														@activity.ActivityType
													</span>
												</td>
												<td>@activity.Name</td>
												<td><small class="text-muted">@activity.Details</small></td>
												<td class="text-end">
													@if (activity.Points > 0) {
														<span class="fw-bold text-success">+@activity.Points</span>
													}
												</td>
											</tr>
										}
									</tbody>
								</table>
							</div>
							@if (FilteredActivities.Count > 200) {
								<div class="text-center py-2 text-muted">
									<small>Showing first 200 of @FilteredActivities.Count records</small>
								</div>
							}
						} else {
							<div class="text-center py-5 text-muted">
								<p class="mb-0">No daily activity data recorded yet.</p>
								<small>Activity data will appear after syncing from the browser extension.</small>
							</div>
						}
					</div>
				</div>
			</div>
		</div>
	}
</div>

@code {
	private bool IsLoading { get; set; } = true;
	private DateTime? DateFrom { get; set; }
	private DateTime? DateTo { get; set; }
	private string SelectedView { get; set; } = "all";

	private List<ActivityRow> AllActivities { get; set; } = new();
	private List<ActivityRow> FilteredActivities { get; set; } = new();
	private List<DailyCount> DailyBreakdown { get; set; } = new();
	private LoginReward? LatestLogin { get; set; }

	// Summary counts
	private int DailyQuestCount { get; set; }
	private int GuildQuestCount { get; set; }
	private int LoginRewardCount { get; set; }
	private int TotalActivityPoints { get; set; }
	private int MaxDailyCount { get; set; }

	protected override async Task OnInitializedAsync() {
		await LoadData();
		IsLoading = false;
	}

	private async Task LoadData() {
		using var context = await DbFactory.CreateDbContextAsync();

		// Load daily quests
		var dailyQuests = await context.DailyQuestCompletions.AsNoTracking()
			.OrderByDescending(q => q.CompletedAt)
			.ToListAsync();

		// Load guild quests
		var guildQuests = await context.GuildQuestCompletions.AsNoTracking()
			.OrderByDescending(q => q.CompletedAt)
			.ToListAsync();

		// Load login rewards
		var loginRewards = await context.LoginRewards.AsNoTracking()
			.OrderByDescending(r => r.ClaimedAt)
			.ToListAsync();

		// Set summary counts
		DailyQuestCount = dailyQuests.Count;
		GuildQuestCount = guildQuests.Count;
		LoginRewardCount = loginRewards.Count;
		TotalActivityPoints = dailyQuests.Sum(q => q.ActivityPoints) +
			guildQuests.Sum(q => q.GuildActivityPoints);

		// Get latest login
		LatestLogin = loginRewards.FirstOrDefault();

		// Build unified activity rows
		AllActivities = new List<ActivityRow>();

		AllActivities.AddRange(dailyQuests.Select(q => new ActivityRow {
			Timestamp = q.CompletedAt,
			ActivityType = "Daily Quest",
			Name = q.QuestName,
			Details = q.Category ?? "",
			Points = q.ActivityPoints,
		}));

		AllActivities.AddRange(guildQuests.Select(q => new ActivityRow {
			Timestamp = q.CompletedAt,
			ActivityType = "Guild Quest",
			Name = q.QuestName,
			Details = q.Difficulty ?? "",
			Points = q.GuildActivityPoints,
		}));

		AllActivities.AddRange(loginRewards.Select(r => new ActivityRow {
			Timestamp = r.ClaimedAt,
			ActivityType = "Login Reward",
			Name = $"Day {r.DayNumber}",
			Details = r.IsVipBonus ? "VIP Bonus" : $"Streak: {r.StreakLength}",
			Points = 0,
		}));

		AllActivities = AllActivities.OrderByDescending(a => a.Timestamp).ToList();

		// Build daily breakdown for chart (all quest types combined)
		var questDates = dailyQuests.Select(q => q.QuestDate.Date)
			.Concat(guildQuests.Select(q => q.QuestDate.Date));

		DailyBreakdown = questDates
			.GroupBy(d => d)
			.Select(g => new DailyCount { Date = g.Key, Count = g.Count() })
			.OrderBy(d => d.Date)
			.ToList();

		MaxDailyCount = DailyBreakdown.Any() ? DailyBreakdown.Max(d => d.Count) : 0;

		ApplyFilters();
	}

	private void ApplyFilters() {
		var filtered = AllActivities.AsEnumerable();

		if (SelectedView != "all") {
			filtered = SelectedView switch {
				"daily" => filtered.Where(a => a.ActivityType == "Daily Quest"),
				"guild" => filtered.Where(a => a.ActivityType == "Guild Quest"),
				"login" => filtered.Where(a => a.ActivityType == "Login Reward"),
				_ => filtered,
			};
		}

		if (DateFrom.HasValue) {
			filtered = filtered.Where(a => a.Timestamp >= DateFrom.Value);
		}

		if (DateTo.HasValue) {
			filtered = filtered.Where(a => a.Timestamp <= DateTo.Value.AddDays(1));
		}

		FilteredActivities = filtered.ToList();
	}

	private void ClearFilters() {
		DateFrom = null;
		DateTo = null;
		SelectedView = "all";
		FilteredActivities = AllActivities;
	}

	/// <summary>
	/// Returns a Bootstrap badge CSS class for activity types.
	/// </summary>
	private static string GetActivityBadgeClass(string activityType) => activityType switch {
		"Daily Quest" => "bg-primary",
		"Guild Quest" => "bg-success",
		"Login Reward" => "bg-info",
		_ => "bg-secondary",
	};

	/// <summary>
	/// View model for the unified activity log table.
	/// </summary>
	private class ActivityRow {
		public DateTime Timestamp { get; set; }
		public string ActivityType { get; set; } = "";
		public string Name { get; set; } = "";
		public string Details { get; set; } = "";
		public int Points { get; set; }
	}

	/// <summary>
	/// Helper for the daily breakdown bar chart.
	/// </summary>
	private class DailyCount {
		public DateTime Date { get; set; }
		public int Count { get; set; }
	}
}
