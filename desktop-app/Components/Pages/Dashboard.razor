@page "/"
@using OrganizedJihad.Data
@using OrganizedJihad.Data.Models
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<GameDatabaseContext> DbFactory

<PageTitle>Dashboard - OrganizedJihad</PageTitle>

<div class="container-fluid">
	<div class="row mb-4">
		<div class="col-12">
			<h1 class="display-4">Hero Wars Tracker</h1>
			<p class="text-muted">Welcome back, @PlayerName</p>
		</div>
	</div>

	@if (IsLoading)
	{
		<div class="row">
			<div class="col-12 text-center">
				<div class="spinner-border" role="status">
					<span class="visually-hidden">Loading...</span>
				</div>
			</div>
		</div>
	}
	else
	{
		<!-- Statistics Cards -->
		<div class="row mb-4">
			<!-- Total Battles Card -->
			<div class="col-md-3">
				<div class="card text-white bg-primary">
					<div class="card-body">
						<h5 class="card-title">Total Battles</h5>
						<p class="card-text display-6">@Stats.TotalBattles</p>
						<small>Win Rate: @WinRate.ToString("F1")%</small>
					</div>
				</div>
			</div>

			<!-- Arena Battles Card -->
			<div class="col-md-3">
				<div class="card text-white bg-success">
					<div class="card-body">
						<h5 class="card-title">Arena Battles</h5>
						<p class="card-text display-6">@Stats.ArenaBattleCount</p>
						<small>Last 7 days</small>
					</div>
				</div>
			</div>

			<!-- Opponents Tracked Card -->
			<div class="col-md-3">
				<div class="card text-white bg-info">
					<div class="card-body">
						<h5 class="card-title">Opponents</h5>
						<p class="card-text display-6">@Stats.OpponentCount</p>
						<small>Tracked</small>
					</div>
				</div>
			</div>

			<!-- Chests Opened Card -->
			<div class="col-md-3">
				<div class="card text-white bg-warning">
					<div class="card-body">
						<h5 class="card-title">Chests Opened</h5>
						<p class="card-text display-6">@Stats.ChestOpeningCount</p>
						<small>All time</small>
					</div>
				</div>
			</div>
		</div>

		<!-- Recent Activity Section -->
		<div class="row mb-4">
			<div class="col-lg-6">
				<div class="card">
					<div class="card-header">
						<h5 class="mb-0">Recent Battles</h5>
					</div>
					<div class="card-body">
						@if (RecentBattles.Any())
						{
							<div class="list-group list-group-flush">
								@foreach (var battle in RecentBattles.Take(5))
								{
									<div class="list-group-item d-flex justify-content-between align-items-center">
										<div>
											<strong>Arena Battle</strong>
											<br />
											<small class="text-muted">vs @(battle.OpponentName ?? battle.OpponentId.ToString())</small>
										</div>
										<div>
											@if (battle.IsWin)
											{
												<span class="badge bg-success">Victory</span>
											}
											else
											{
												<span class="badge bg-danger">Defeat</span>
											}
											<br />
											<small class="text-muted">@GetRelativeTime(battle.Timestamp)</small>
										</div>
									</div>
								}
							</div>
						}
						else
						{
							<p class="text-muted">No battles recorded yet. Start playing to see your battle history!</p>
						}
					</div>
				</div>
			</div>

			<div class="col-lg-6">
				<div class="card">
					<div class="card-header">
						<h5 class="mb-0">Recent Chest Openings</h5>
					</div>
					<div class="card-body">
						@if (RecentChests.Any())
						{
							<div class="list-group list-group-flush">
								@foreach (var chest in RecentChests.Take(5))
								{
									<div class="list-group-item d-flex justify-content-between align-items-center">
										<div>
											<strong>@chest.ChestType</strong>
											<br />
											<small class="text-muted">@chest.Timestamp.ToString("MMM dd, yyyy HH:mm")</small>
										</div>
										<div>
											<span class="badge bg-info">@chest.Drops.Count items</span>
										</div>
									</div>
								}
							</div>
						}
						else
						{
							<p class="text-muted">No chests opened yet.</p>
						}
					</div>
				</div>
			</div>
		</div>

		<!-- Player Progress Section -->
		<div class="row mb-4">
			<div class="col-12">
				<div class="card">
					<div class="card-header">
						<h5 class="mb-0">Player Progress</h5>
					</div>
					<div class="card-body">
						@if (LatestSnapshot != null)
						{
							<div class="row">
								<div class="col-md-4">
									<p><strong>Level:</strong> @LatestSnapshot.Level</p>
									<p><strong>Team Power:</strong> @LatestSnapshot.TeamPower.ToString("N0")</p>
								</div>
								<div class="col-md-4">
									<p><strong>Gold:</strong> @LatestSnapshot.Gold.ToString("N0")</p>
									<p><strong>Emeralds:</strong> @LatestSnapshot.Emeralds.ToString("N0")</p>
									<p><strong>Guild:</strong> @(LatestSnapshot.GuildName ?? "No Guild")</p>
								</div>
								<div class="col-md-4">
									<p><strong>Arena Rank:</strong> @LatestSnapshot.ArenaRank</p>
									<p><strong>Grand Arena Rank:</strong> @LatestSnapshot.GrandArenaRank</p>
									<p><strong>Titan Arena Rank:</strong> @LatestSnapshot.TitanArenaRank</p>
								</div>
							</div>
							<small class="text-muted">Last updated: @LatestSnapshot.Timestamp.ToString("MMM dd, yyyy HH:mm")</small>
						}
						else
						{
							<p class="text-muted">No player data available yet. Data will appear after syncing from the browser extension.</p>
						}
					</div>
				</div>
			</div>
		</div>

		<!-- Last Sync Info -->
		<div class="row">
			<div class="col-12">
				<div class="alert alert-info">
					<strong>Last Sync:</strong> @(Stats.LastSync?.ToString("MMM dd, yyyy HH:mm") ?? "Never")
					<span class="float-end">
						<a href="/sync" class="btn btn-sm btn-primary">Sync Now</a>
					</span>
				</div>
			</div>
		</div>
	}
</div>

@code {
	private bool IsLoading { get; set; } = true;
	private string PlayerName { get; set; } = "Player";
	private DatabaseStats Stats { get; set; } = new();
	private PlayerSnapshot? LatestSnapshot { get; set; }
	private List<ArenaBattle> RecentBattles { get; set; } = new();
	private List<ChestOpening> RecentChests { get; set; } = new();
	private double WinRate { get; set; }

	protected override async Task OnInitializedAsync()
	{
		await LoadDashboardData();
		IsLoading = false;
	}

	private async Task LoadDashboardData()
	{
		using var context = await DbFactory.CreateDbContextAsync();

		// Load statistics
		Stats = new DatabaseStats
		{
			PlayerSnapshotCount = await context.PlayerSnapshots.CountAsync(),
			ArenaBattleCount = await context.ArenaBattles.CountAsync(),
			GrandArenaBattleCount = await context.GrandArenaBattles.CountAsync(),
			TitanArenaBattleCount = await context.TitanArenaBattles.CountAsync(),
			GuildWarBattleCount = await context.GuildWarBattles.CountAsync(),
			RaidBossAttackCount = await context.RaidBossAttacks.CountAsync(),
			ChestOpeningCount = await context.ChestOpenings.CountAsync(),
			OpponentCount = await context.Opponents.CountAsync(),
			GoalCount = await context.Goals.CountAsync(),
			CalendarEventCount = await context.CalendarEvents.CountAsync()
		};

		// Calculate total battles and win rate
		Stats.TotalBattles = Stats.ArenaBattleCount + Stats.GrandArenaBattleCount +
			Stats.TitanArenaBattleCount + Stats.GuildWarBattleCount;

		// Get latest snapshot
		LatestSnapshot = await context.PlayerSnapshots
			.OrderByDescending(s => s.Timestamp)
			.FirstOrDefaultAsync();

		if (LatestSnapshot != null)
		{
			PlayerName = LatestSnapshot.PlayerName;
		}

		// Get recent battles (combining all types)
		var arenaBattles = await context.ArenaBattles
			.OrderByDescending(b => b.Timestamp)
			.Take(10)
			.ToListAsync();

		RecentBattles = arenaBattles;

		// Calculate win rate
		if (Stats.TotalBattles > 0)
		{
			var wins = arenaBattles.Count(b => b.IsWin);
			WinRate = (wins / (double)arenaBattles.Count) * 100;
		}

		// Get recent chests
		RecentChests = await context.ChestOpenings
			.Include(c => c.Drops)
			.OrderByDescending(c => c.Timestamp)
			.Take(10)
			.ToListAsync();

		// Get last sync metadata
		var syncMetadata = await context.SyncMetadata
			.OrderByDescending(m => m.UpdatedAt)
			.FirstOrDefaultAsync();

		Stats.LastSync = syncMetadata?.UpdatedAt;
	}

	private string GetRelativeTime(DateTime timestamp)
	{
		var timeSpan = DateTime.UtcNow - timestamp.ToUniversalTime();

		if (timeSpan.TotalMinutes < 1)
			return "Just now";
		if (timeSpan.TotalMinutes < 60)
			return $"{(int)timeSpan.TotalMinutes}m ago";
		if (timeSpan.TotalHours < 24)
			return $"{(int)timeSpan.TotalHours}h ago";
		if (timeSpan.TotalDays < 7)
			return $"{(int)timeSpan.TotalDays}d ago";

		return timestamp.ToString("MMM dd");
	}

	private class DatabaseStats
	{
		public int PlayerSnapshotCount { get; set; }
		public int ArenaBattleCount { get; set; }
		public int GrandArenaBattleCount { get; set; }
		public int TitanArenaBattleCount { get; set; }
		public int GuildWarBattleCount { get; set; }
		public int RaidBossAttackCount { get; set; }
		public int ChestOpeningCount { get; set; }
		public int OpponentCount { get; set; }
		public int GoalCount { get; set; }
		public int CalendarEventCount { get; set; }
		public int TotalBattles { get; set; }
		public DateTime? LastSync { get; set; }
	}
}
