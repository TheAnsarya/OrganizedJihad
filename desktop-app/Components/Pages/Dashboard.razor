@page "/"
@using OrganizedJihad.Data
@using OrganizedJihad.Data.Models
@using Microsoft.EntityFrameworkCore
@using System.Net.Http.Json
@inject IDbContextFactory<GameDatabaseContext> DbFactory
@inject RecommendationSettingsService RecommendationSettings

<PageTitle>Dashboard - OrganizedJihad</PageTitle>

<div class="container-fluid">
	<div class="row mb-4">
		<div class="col-12">
			<h1 class="display-4">Hero Wars Tracker</h1>
			<p class="text-muted">Welcome back, @PlayerName</p>
		</div>
	</div>

	@if (IsLoading)
	{
		<div class="row">
			<div class="col-12 text-center">
				<div class="spinner-border" role="status">
					<span class="visually-hidden">Loading...</span>
				</div>
			</div>
		</div>
	}
	else
	{
		<!-- Statistics Cards -->
		<div class="row mb-4">
			<!-- Total Battles Card -->
			<div class="col-md-3">
				<div class="card text-white bg-primary">
					<div class="card-body">
						<h5 class="card-title">Total Battles</h5>
						<p class="card-text display-6">@Stats.TotalBattles</p>
						<small>Win Rate: @WinRate.ToString("F1")%</small>
					</div>
				</div>
			</div>

			<!-- Arena Battles Card -->
			<div class="col-md-3">
				<div class="card text-white bg-success">
					<div class="card-body">
						<h5 class="card-title">Arena Battles</h5>
						<p class="card-text display-6">@Stats.ArenaBattleCount</p>
						<small>Last 7 days</small>
					</div>
				</div>
			</div>

			<!-- Opponents Tracked Card -->
			<div class="col-md-3">
				<div class="card text-white bg-info">
					<div class="card-body">
						<h5 class="card-title">Opponents</h5>
						<p class="card-text display-6">@Stats.OpponentCount</p>
						<small>Tracked</small>
					</div>
				</div>
			</div>

			<!-- Chests Opened Card -->
			<div class="col-md-3">
				<div class="card text-white bg-warning">
					<div class="card-body">
						<h5 class="card-title">Chests Opened</h5>
						<p class="card-text display-6">@Stats.ChestOpeningCount</p>
						<small>All time</small>
					</div>
				</div>
			</div>
		</div>

		<!-- Recent Activity Section -->
		<div class="row mb-4">
			<div class="col-lg-6">
				<div class="card">
					<div class="card-header">
						<h5 class="mb-0">Recent Battles</h5>
					</div>
					<div class="card-body">
						@if (RecentBattles.Any())
						{
							<div class="list-group list-group-flush">
								@foreach (var battle in RecentBattles.Take(5))
								{
									<div class="list-group-item d-flex justify-content-between align-items-center">
										<div>
											<strong>Arena Battle</strong>
											<br />
											<small class="text-muted">vs @(battle.OpponentName ?? battle.OpponentId.ToString())</small>
										</div>
										<div>
											@if (battle.IsWin)
											{
												<span class="badge bg-success">Victory</span>
											}
											else
											{
												<span class="badge bg-danger">Defeat</span>
											}
											<br />
											<small class="text-muted">@GetRelativeTime(battle.Timestamp)</small>
										</div>
									</div>
								}
							</div>
						}
						else
						{
							<p class="text-muted">No battles recorded yet. Start playing to see your battle history!</p>
						}
					</div>
				</div>
			</div>

			<div class="col-lg-6">
				<div class="card">
					<div class="card-header">
						<h5 class="mb-0">Recent Chest Openings</h5>
					</div>
					<div class="card-body">
						@if (RecentChests.Any())
						{
							<div class="list-group list-group-flush">
								@foreach (var chest in RecentChests.Take(5))
								{
									<div class="list-group-item d-flex justify-content-between align-items-center">
										<div>
											<strong>@chest.ChestType</strong>
											<br />
											<small class="text-muted">@chest.Timestamp.ToString("MMM dd, yyyy HH:mm")</small>
										</div>
										<div>
											<span class="badge bg-info">@chest.Drops.Count items</span>
										</div>
									</div>
								}
							</div>
						}
						else
						{
							<p class="text-muted">No chests opened yet.</p>
						}
					</div>
				</div>
			</div>
		</div>

		<div class="row mb-4">
			<div class="col-12">
				<div class="card border-primary">
					<div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
						<h5 class="mb-0">Arena Recommendations</h5>
						<small>@(RecommendationCards.Any() ? $"Top {RecommendationCards.Count} candidates" : "No candidates") • @RecommendationSource</small>
					</div>
					<div class="card-body">
						<div class="mb-3">
							<small class="text-muted">Recommendation API: @RecommendationApiBaseUrl</small>
							<a class="btn btn-sm btn-outline-secondary ms-2" href="/settings">Change</a>
						</div>

						@if (!string.IsNullOrWhiteSpace(RecommendationStatusMessage))
						{
							<div class="alert alert-secondary py-2 mb-3">
								<small>@RecommendationStatusMessage</small>
							</div>
						}

						@if (RecommendationCards.Any())
						{
							<div class="row g-3">
								@foreach (var rec in RecommendationCards)
								{
									<div class="col-lg-4 col-md-6">
										<div class="card h-100 border-0 bg-light">
											<div class="card-body">
												<h6 class="card-title mb-1">@rec.TeamPreview</h6>
												<p class="text-muted small mb-2">@rec.Rationale</p>
												<div class="small">
													<div><strong>Sim:</strong> @((rec.SimulatedWinProbability * 100).ToString("F1"))%</div>
													<div><strong>Weighted:</strong> @((rec.WeightedWinRate * 100).ToString("F1"))%</div>
													<div><strong>CI:</strong> @((rec.ConfidenceLow * 100).ToString("F1"))% - @((rec.ConfidenceHigh * 100).ToString("F1"))%</div>
													<div><strong>Samples:</strong> @rec.Battles</div>
												</div>
												<a class="btn btn-sm btn-outline-primary mt-2" href="@BuildBattleDrilldownUrl(rec)">View Samples</a>
											</div>
										</div>
									</div>
								}
							</div>
						}
						else
						{
							<p class="text-muted mb-0">No recommendation candidates available yet. Play and sync more arena battles to generate suggestions.</p>
						}
					</div>
				</div>
			</div>
		</div>

		<!-- Player Progress Section -->
		<div class="row mb-4">
			<div class="col-12">
				<div class="card">
					<div class="card-header">
						<h5 class="mb-0">Player Progress</h5>
					</div>
					<div class="card-body">
						@if (LatestSnapshot != null)
						{
							<div class="row">
								<div class="col-md-4">
									<p><strong>Level:</strong> @LatestSnapshot.Level</p>
									<p><strong>Team Power:</strong> @LatestSnapshot.TeamPower.ToString("N0")</p>
								</div>
								<div class="col-md-4">
									<p><strong>Gold:</strong> @LatestSnapshot.Gold.ToString("N0")</p>
									<p><strong>Emeralds:</strong> @LatestSnapshot.Emeralds.ToString("N0")</p>
									<p><strong>Guild:</strong> @(LatestSnapshot.GuildName ?? "No Guild")</p>
								</div>
								<div class="col-md-4">
									<p><strong>Arena Rank:</strong> @LatestSnapshot.ArenaRank</p>
									<p><strong>Grand Arena Rank:</strong> @LatestSnapshot.GrandArenaRank</p>
									<p><strong>Titan Arena Rank:</strong> @LatestSnapshot.TitanArenaRank</p>
								</div>
							</div>
							<small class="text-muted">Last updated: @LatestSnapshot.Timestamp.ToString("MMM dd, yyyy HH:mm")</small>
						}
						else
						{
							<p class="text-muted">No player data available yet. Data will appear after syncing from the browser extension.</p>
						}
					</div>
				</div>
			</div>
		</div>

		<!-- Last Sync Info -->
		<div class="row">
			<div class="col-12">
				<div class="alert alert-info">
					<strong>Last Sync:</strong> @(Stats.LastSync?.ToString("MMM dd, yyyy HH:mm") ?? "Never")
					<span class="float-end">
						<a href="/sync" class="btn btn-sm btn-primary">Sync Now</a>
					</span>
				</div>
			</div>
		</div>
	}
</div>

@code {
	private bool IsLoading { get; set; } = true;
	private string PlayerName { get; set; } = "Player";
	private DatabaseStats Stats { get; set; } = new();
	private PlayerSnapshot? LatestSnapshot { get; set; }
	private List<ArenaBattle> RecentBattles { get; set; } = new();
	private List<ChestOpening> RecentChests { get; set; } = new();
	private List<ArenaBattle> RecommendationSamplePool { get; set; } = new();
	private List<RecommendationCard> RecommendationCards { get; set; } = new();
	private string RecommendationSource { get; set; } = "Local";
	private string RecommendationStatusMessage { get; set; } = string.Empty;
	private string RecommendationApiBaseUrl { get; set; } = "http://localhost:5124";
	private double WinRate { get; set; }

	protected override async Task OnInitializedAsync()
	{
		RecommendationApiBaseUrl = RecommendationSettings.GetRecommendationApiBaseUrl();
		await LoadDashboardData();
		IsLoading = false;
	}

	private async Task LoadDashboardData()
	{
		using var context = await DbFactory.CreateDbContextAsync();

		// Load statistics
		Stats = new DatabaseStats
		{
			PlayerSnapshotCount = await context.PlayerSnapshots.CountAsync(),
			ArenaBattleCount = await context.ArenaBattles.CountAsync(),
			GrandArenaBattleCount = await context.GrandArenaBattles.CountAsync(),
			TitanArenaBattleCount = await context.TitanArenaBattles.CountAsync(),
			GuildWarBattleCount = await context.GuildWarBattles.CountAsync(),
			RaidBossAttackCount = await context.RaidBossAttacks.CountAsync(),
			ChestOpeningCount = await context.ChestOpenings.CountAsync(),
			OpponentCount = await context.Opponents.CountAsync(),
			GoalCount = await context.Goals.CountAsync(),
			CalendarEventCount = await context.CalendarEvents.CountAsync()
		};

		// Calculate total battles and win rate
		Stats.TotalBattles = Stats.ArenaBattleCount + Stats.GrandArenaBattleCount +
			Stats.TitanArenaBattleCount + Stats.GuildWarBattleCount;

		// Get latest snapshot
		LatestSnapshot = await context.PlayerSnapshots
			.OrderByDescending(s => s.Timestamp)
			.FirstOrDefaultAsync();

		if (LatestSnapshot != null)
		{
			PlayerName = LatestSnapshot.PlayerName;
		}

		// Get recent battles (combining all types)
		var arenaBattles = await context.ArenaBattles
			.OrderByDescending(b => b.Timestamp)
			.Take(10)
			.ToListAsync();

		var recommendationSamples = await context.ArenaBattles
			.AsNoTracking()
			.OrderByDescending(b => b.Timestamp)
			.Take(500)
			.ToListAsync();

		RecentBattles = arenaBattles;
		RecommendationSamplePool = recommendationSamples;
		RecommendationCards = await LoadRecommendationCardsAsync(recommendationSamples, LatestSnapshot?.TeamPower);

		// Calculate win rate
		if (Stats.TotalBattles > 0)
		{
			var wins = arenaBattles.Count(b => b.IsWin);
			WinRate = (wins / (double)arenaBattles.Count) * 100;
		}

		// Get recent chests
		RecentChests = await context.ChestOpenings
			.Include(c => c.Drops)
			.OrderByDescending(c => c.Timestamp)
			.Take(10)
			.ToListAsync();

		// Get last sync metadata
		var syncMetadata = await context.SyncMetadata
			.OrderByDescending(m => m.UpdatedAt)
			.FirstOrDefaultAsync();

		Stats.LastSync = syncMetadata?.UpdatedAt;
	}

	private string GetRelativeTime(DateTime timestamp)
	{
		var timeSpan = DateTime.UtcNow - timestamp.ToUniversalTime();

		if (timeSpan.TotalMinutes < 1)
			return "Just now";
		if (timeSpan.TotalMinutes < 60)
			return $"{(int)timeSpan.TotalMinutes}m ago";
		if (timeSpan.TotalHours < 24)
			return $"{(int)timeSpan.TotalHours}h ago";
		if (timeSpan.TotalDays < 7)
			return $"{(int)timeSpan.TotalDays}d ago";

		return timestamp.ToString("MMM dd");
	}

	private class DatabaseStats
	{
		public int PlayerSnapshotCount { get; set; }
		public int ArenaBattleCount { get; set; }
		public int GrandArenaBattleCount { get; set; }
		public int TitanArenaBattleCount { get; set; }
		public int GuildWarBattleCount { get; set; }
		public int RaidBossAttackCount { get; set; }
		public int ChestOpeningCount { get; set; }
		public int OpponentCount { get; set; }
		public int GoalCount { get; set; }
		public int CalendarEventCount { get; set; }
		public int TotalBattles { get; set; }
		public DateTime? LastSync { get; set; }
	}

	private static List<RecommendationCard> BuildRecommendationCards(IEnumerable<ArenaBattle> battles, int? teamPower) {
		var now = DateTime.UtcNow;

		return battles
			.Where(b => !string.IsNullOrWhiteSpace(b.OurTeam))
			.GroupBy(b => NormalizeTeamKey(b.OurTeam))
			.Select(group => {
				var samples = group.ToList();
				var sampleCount = samples.Count;
				var wins = samples.Count(b => b.IsWin);
				var weighted = samples.Select(b => {
					var ageDays = Math.Max(0, (now - b.Timestamp).TotalDays);
					var w = Math.Exp(-ageDays / 30d);
					return new { b.IsWin, Weight = w };
				}).ToList();

				var weightTotal = weighted.Sum(x => x.Weight);
				var weightedWins = weighted.Where(x => x.IsWin).Sum(x => x.Weight);
				var weightedRate = weightTotal <= 0 ? 0 : weightedWins / weightTotal;

				var avgOpponentPower = (int)Math.Round(samples.Average(b => b.OpponentPower));
				var confidence = Math.Min(1d, sampleCount / 20d);
				var powerDeltaRatio = avgOpponentPower > 0
					? ((teamPower ?? avgOpponentPower) - avgOpponentPower) / (double)avgOpponentPower
					: 0d;
				powerDeltaRatio = Math.Clamp(powerDeltaRatio, -0.75, 0.75);

				var simulated = Math.Clamp(weightedRate + (powerDeltaRatio * 0.18) + ((confidence - 0.5d) * 0.04), 0.05, 0.95);
				var stdError = Math.Sqrt((simulated * (1 - simulated)) / Math.Max(1, sampleCount));
				var low = Math.Clamp(simulated - (1.96 * stdError), 0, 1);
				var high = Math.Clamp(simulated + (1.96 * stdError), 0, 1);
				var score = (simulated * 0.75d) + (confidence * 0.25d);

				return new RecommendationCard {
					TeamKey = group.Key,
					TeamPreview = BuildTeamPreview(group.Key),
					Battles = sampleCount,
					WeightedWinRate = weightedRate,
					SimulatedWinProbability = simulated,
					ConfidenceLow = low,
					ConfidenceHigh = high,
					Score = score,
					Rationale = $"{wins}/{sampleCount} wins, avg opponent power {avgOpponentPower:N0}",
				};
			})
			.Where(x => x.Battles >= 2)
			.OrderByDescending(x => x.Score)
			.ThenByDescending(x => x.Battles)
			.Take(3)
			.ToList();
	}

	private static string NormalizeTeamKey(string? teamKey) {
		if (string.IsNullOrWhiteSpace(teamKey)) {
			return "[unknown]";
		}

		return teamKey.Trim();
	}

	private static string BuildTeamPreview(string teamKey) {
		if (string.IsNullOrWhiteSpace(teamKey) || teamKey == "[unknown]") {
			return "Unknown Team";
		}

		if (teamKey.Length <= 42) {
			return teamKey;
		}

		return $"{teamKey[..42]}...";
	}

	private static string BuildBattleDrilldownUrl(RecommendationCard recommendation) {
		var encodedTeam = Uri.EscapeDataString(recommendation.TeamKey);
		return $"/battles?type=arena&team={encodedTeam}";
	}

	private async Task<List<RecommendationCard>> LoadRecommendationCardsAsync(IEnumerable<ArenaBattle> localSamples, int? teamPower) {
		try {
			using var client = new HttpClient {
				Timeout = TimeSpan.FromSeconds(2),
			};
			var endpoint = BuildRecommendationApiEndpoint();
			var apiResult = await client.GetFromJsonAsync<ApiBattleRecommendationResponse>(
				endpoint
			);

			var recommendations = apiResult?.Recommendations;
			if (recommendations != null && recommendations.Count > 0) {
				RecommendationSource = "API";
				RecommendationStatusMessage = string.Empty;
				return recommendations.Select(r => new RecommendationCard {
					TeamKey = string.IsNullOrWhiteSpace(r.TeamKey) ? "[unknown]" : r.TeamKey,
					TeamPreview = string.IsNullOrWhiteSpace(r.TeamPreview) ? BuildTeamPreview(r.TeamKey ?? "[unknown]") : r.TeamPreview,
					Battles = r.Battles,
					WeightedWinRate = r.WeightedWinRate,
					SimulatedWinProbability = r.SimulatedWinProbability,
					ConfidenceLow = r.SimulationConfidenceLow,
					ConfidenceHigh = r.SimulationConfidenceHigh,
					Score = r.Score,
					Rationale = string.IsNullOrWhiteSpace(r.Rationale) ? "API recommendation" : r.Rationale,
				}).ToList();
			}
		} catch {
			// Fall through to local recommendation generation.
		}

		RecommendationSource = "Local Fallback";
		RecommendationStatusMessage = "API recommendations unavailable; showing local estimates from recent arena history.";
		return BuildRecommendationCards(localSamples, teamPower);
	}

	private string BuildRecommendationApiEndpoint() {
		var baseUrl = RecommendationApiBaseUrl?.Trim();
		if (string.IsNullOrWhiteSpace(baseUrl)) {
			baseUrl = "http://localhost:5124";
		}

		baseUrl = baseUrl.TrimEnd('/');
		return $"{baseUrl}/api/sync/battles/recommendations?battleType=arena&limit=3&minSamples=2";
	}

	private sealed class RecommendationCard {
		public string TeamKey { get; set; } = string.Empty;
		public string TeamPreview { get; set; } = string.Empty;
		public int Battles { get; set; }
		public double WeightedWinRate { get; set; }
		public double SimulatedWinProbability { get; set; }
		public double ConfidenceLow { get; set; }
		public double ConfidenceHigh { get; set; }
		public double Score { get; set; }
		public string Rationale { get; set; } = string.Empty;
	}

	private sealed class ApiBattleRecommendationResponse {
		public List<ApiBattleRecommendationCandidate> Recommendations { get; set; } = new();
	}

	private sealed class ApiBattleRecommendationCandidate {
		public string TeamKey { get; set; } = string.Empty;
		public string TeamPreview { get; set; } = string.Empty;
		public int Battles { get; set; }
		public double WeightedWinRate { get; set; }
		public double SimulatedWinProbability { get; set; }
		public double SimulationConfidenceLow { get; set; }
		public double SimulationConfidenceHigh { get; set; }
		public double Score { get; set; }
		public string Rationale { get; set; } = string.Empty;
	}
}
