@page "/resources"
@using OrganizedJihad.Data
@using OrganizedJihad.Data.Models
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<GameDatabaseContext> DbFactory

<PageTitle>Resources - OrganizedJihad</PageTitle>

<div class="container-fluid">
	<div class="row mb-4">
		<div class="col-12">
			<h1 class="display-5">Resource Tracker</h1>
			<p class="text-muted">Track earning and spending of emeralds, gold, coins, and other resources.</p>
		</div>
	</div>

	@if (IsLoading) {
		<div class="row">
			<div class="col-12 text-center py-5">
				<div class="spinner-border" role="status">
					<span class="visually-hidden">Loading...</span>
				</div>
			</div>
		</div>
	} else {
		<!-- Current Balances (from latest snapshot) -->
		@if (LatestSnapshot != null) {
			<div class="row mb-4">
				<div class="col-12">
					<h5 class="text-muted mb-3">Current Balances
						<small class="text-muted">(as of @LatestSnapshot.Timestamp.ToString("MMM dd, yyyy HH:mm"))</small>
					</h5>
				</div>
				<div class="col-md-2">
					<div class="card border-success cursor-pointer @(SelectedResource == "emeralds" ? "border-3" : "")"
						 @onclick='() => SelectResource("emeralds")'>
						<div class="card-body py-2 text-center">
							<small class="text-muted">Emeralds</small>
							<p class="display-6 mb-0 text-success">@LatestSnapshot.Emeralds.ToString("N0")</p>
						</div>
					</div>
				</div>
				<div class="col-md-2">
					<div class="card border-warning cursor-pointer @(SelectedResource == "gold" ? "border-3" : "")"
						 @onclick='() => SelectResource("gold")'>
						<div class="card-body py-2 text-center">
							<small class="text-muted">Gold</small>
							<p class="display-6 mb-0 text-warning">@LatestSnapshot.Gold.ToString("N0")</p>
						</div>
					</div>
				</div>
				<div class="col-md-2">
					<div class="card cursor-pointer @(SelectedResource == "arena_coins" ? "border-3 border-primary" : "")"
						 @onclick='() => SelectResource("arena_coins")'>
						<div class="card-body py-2 text-center">
							<small class="text-muted">Arena Coins</small>
							<p class="display-6 mb-0">@LatestSnapshot.ArenaCoins.ToString("N0")</p>
						</div>
					</div>
				</div>
				<div class="col-md-2">
					<div class="card cursor-pointer @(SelectedResource == "grand_arena_coins" ? "border-3 border-info" : "")"
						 @onclick='() => SelectResource("grand_arena_coins")'>
						<div class="card-body py-2 text-center">
							<small class="text-muted">GA Coins</small>
							<p class="display-6 mb-0">@LatestSnapshot.GrandArenaCoins.ToString("N0")</p>
						</div>
					</div>
				</div>
				<div class="col-md-2">
					<div class="card cursor-pointer @(SelectedResource == "guild_coins" ? "border-3 border-secondary" : "")"
						 @onclick='() => SelectResource("guild_coins")'>
						<div class="card-body py-2 text-center">
							<small class="text-muted">Guild Coins</small>
							<p class="display-6 mb-0">@LatestSnapshot.GuildCoins.ToString("N0")</p>
						</div>
					</div>
				</div>
				<div class="col-md-2">
					<div class="card cursor-pointer @(SelectedResource == "titan_coins" ? "border-3 border-dark" : "")"
						 @onclick='() => SelectResource("titan_coins")'>
						<div class="card-body py-2 text-center">
							<small class="text-muted">Titan Coins</small>
							<p class="display-6 mb-0">@LatestSnapshot.TitanArenaCoins.ToString("N0")</p>
						</div>
					</div>
				</div>
			</div>
		}

		<!-- Resource Filter Bar -->
		<div class="row mb-3">
			<div class="col-md-3">
				<select class="form-select" @bind="SelectedResource">
					<option value="">All Resources</option>
					<option value="emeralds">Emeralds</option>
					<option value="gold">Gold</option>
					<option value="arena_coins">Arena Coins</option>
					<option value="grand_arena_coins">Grand Arena Coins</option>
					<option value="guild_coins">Guild Coins</option>
					<option value="tower_coins">Tower Coins</option>
					<option value="titan_coins">Titan Coins</option>
				</select>
			</div>
			<div class="col-md-2">
				<select class="form-select" @bind="SelectedDirection">
					<option value="">All Transactions</option>
					<option value="earned">Earned (gains)</option>
					<option value="spent">Spent (losses)</option>
				</select>
			</div>
			<div class="col-md-2">
				<select class="form-select" @bind="SelectedSource">
					<option value="">All Sources</option>
					@foreach (var s in Sources) {
						<option value="@s">@FormatSource(s)</option>
					}
				</select>
			</div>
			<div class="col-md-2">
				<input type="date" class="form-control" @bind="DateFrom" />
			</div>
			<div class="col-md-3 d-flex align-items-end">
				<button class="btn btn-primary me-2" @onclick="ApplyFilters">Apply</button>
				<button class="btn btn-outline-secondary" @onclick="ClearFilters">Clear</button>
			</div>
		</div>

		<!-- Earning/Spending Summary -->
		@if (FilteredRows.Any()) {
			<div class="row mb-4">
				<div class="col-md-4">
					<div class="card border-success">
						<div class="card-body py-2">
							<h6 class="card-title text-success mb-0">Total Earned</h6>
							<p class="display-6 mb-0 text-success">+@TotalEarned.ToString("N0")</p>
							<small class="text-muted">@EarnedCount transactions</small>
						</div>
					</div>
				</div>
				<div class="col-md-4">
					<div class="card border-danger">
						<div class="card-body py-2">
							<h6 class="card-title text-danger mb-0">Total Spent</h6>
							<p class="display-6 mb-0 text-danger">@TotalSpent.ToString("N0")</p>
							<small class="text-muted">@SpentCount transactions</small>
						</div>
					</div>
				</div>
				<div class="col-md-4">
					<div class="card @(NetChange >= 0 ? "border-success" : "border-danger")">
						<div class="card-body py-2">
							<h6 class="card-title mb-0">Net Change</h6>
							<p class="display-6 mb-0 @(NetChange >= 0 ? "text-success" : "text-danger")">
								@(NetChange >= 0 ? "+" : "")@NetChange.ToString("N0")
							</p>
							<small class="text-muted">@FilteredRows.Count total transactions</small>
						</div>
					</div>
				</div>
			</div>

			<!-- Source Breakdown -->
			<div class="row mb-4">
				<div class="col-md-6">
					<div class="card">
						<div class="card-header">
							<h5 class="mb-0">Earnings by Source</h5>
						</div>
						<div class="card-body">
							@{
								var earningsBySource = FilteredRows
									.Where(r => r.Amount > 0)
									.GroupBy(r => r.Source)
									.Select(g => new { Source = g.Key, Total = g.Sum(r => r.Amount) })
									.OrderByDescending(s => s.Total).ToList();
							}
							@if (earningsBySource.Any()) {
								var maxEarnings = earningsBySource.Max(s => s.Total);
								@foreach (var src in earningsBySource) {
									var pct = maxEarnings > 0 ? (int)((src.Total / (double)maxEarnings) * 100) : 0;
									<div class="mb-2">
										<div class="d-flex justify-content-between">
											<span class="fw-bold">@FormatSource(src.Source)</span>
											<span class="text-success">+@src.Total.ToString("N0")</span>
										</div>
										<div class="progress" style="height: 6px;">
											<div class="progress-bar bg-success" style="width: @(pct)%"></div>
										</div>
									</div>
								}
							} else {
								<p class="text-muted">No earnings in selected range.</p>
							}
						</div>
					</div>
				</div>
				<div class="col-md-6">
					<div class="card">
						<div class="card-header">
							<h5 class="mb-0">Spending by Source</h5>
						</div>
						<div class="card-body">
							@{
								var spendingBySource = FilteredRows
									.Where(r => r.Amount < 0)
									.GroupBy(r => r.Source)
									.Select(g => new { Source = g.Key, Total = Math.Abs(g.Sum(r => r.Amount)) })
									.OrderByDescending(s => s.Total).ToList();
							}
							@if (spendingBySource.Any()) {
								var maxSpending = spendingBySource.Max(s => s.Total);
								@foreach (var src in spendingBySource) {
									var pct = maxSpending > 0 ? (int)((src.Total / (double)maxSpending) * 100) : 0;
									<div class="mb-2">
										<div class="d-flex justify-content-between">
											<span class="fw-bold">@FormatSource(src.Source)</span>
											<span class="text-danger">-@src.Total.ToString("N0")</span>
										</div>
										<div class="progress" style="height: 6px;">
											<div class="progress-bar bg-danger" style="width: @(pct)%"></div>
										</div>
									</div>
								}
							} else {
								<p class="text-muted">No spending in selected range.</p>
							}
						</div>
					</div>
				</div>
			</div>
		}

		<!-- Transaction Log -->
		<div class="row">
			<div class="col-12">
				<div class="card">
					<div class="card-header d-flex justify-content-between align-items-center">
						<h5 class="mb-0">Transaction Log</h5>
						<span class="badge bg-secondary">@FilteredRows.Count records</span>
					</div>
					<div class="card-body p-0">
						@if (FilteredRows.Any()) {
							<div class="table-responsive">
								<table class="table table-striped table-hover mb-0">
									<thead class="table-dark">
										<tr>
											<th>Time</th>
											<th>Resource</th>
											<th class="text-end">Amount</th>
											<th>Source</th>
											<th>Details</th>
										</tr>
									</thead>
									<tbody>
										@foreach (var row in FilteredRows.Take(300)) {
											<tr>
												<td><small>@row.Timestamp.ToString("MMM dd HH:mm")</small></td>
												<td>
													<span class="badge @GetResourceBadgeClass(row.ResourceType)">
														@FormatResourceType(row.ResourceType)
													</span>
												</td>
												<td class="text-end fw-bold @(row.Amount >= 0 ? "text-success" : "text-danger")">
													@(row.Amount >= 0 ? "+" : "")@row.Amount.ToString("N0")
												</td>
												<td>@FormatSource(row.Source)</td>
												<td><small class="text-muted">@(row.SourceDetail ?? "—")</small></td>
											</tr>
										}
									</tbody>
								</table>
							</div>
							@if (FilteredRows.Count > 300) {
								<div class="text-center py-2 text-muted">
									<small>Showing first 300 of @FilteredRows.Count transactions</small>
								</div>
							}
						} else {
							<div class="text-center py-5 text-muted">
								<p class="mb-0">No resource transactions recorded yet.</p>
								<small>Resource data will appear after syncing from the browser extension.</small>
							</div>
						}
					</div>
				</div>
			</div>
		</div>
	}
</div>

<style>
	.cursor-pointer { cursor: pointer; }
	.cursor-pointer:hover { opacity: 0.85; }
</style>

@code {
	private bool IsLoading { get; set; } = true;
	private string SelectedResource { get; set; } = "";
	private string SelectedDirection { get; set; } = "";
	private string SelectedSource { get; set; } = "";
	private DateTime? DateFrom { get; set; }

	private PlayerSnapshot? LatestSnapshot { get; set; }
	private List<ResourceTransaction> AllRows { get; set; } = new();
	private List<ResourceTransaction> FilteredRows { get; set; } = new();
	private List<string> Sources { get; set; } = new();

	// Computed summaries
	private long TotalEarned { get; set; }
	private long TotalSpent { get; set; }
	private long NetChange { get; set; }
	private int EarnedCount { get; set; }
	private int SpentCount { get; set; }

	protected override async Task OnInitializedAsync() {
		await LoadData();
		IsLoading = false;
	}

	private async Task LoadData() {
		using var context = await DbFactory.CreateDbContextAsync();

		LatestSnapshot = await context.PlayerSnapshots.AsNoTracking()
			.OrderByDescending(s => s.Timestamp)
			.FirstOrDefaultAsync();

		AllRows = await context.ResourceTransactions.AsNoTracking()
			.OrderByDescending(r => r.Timestamp)
			.ToListAsync();

		Sources = AllRows.Select(r => r.Source)
			.Where(s => !string.IsNullOrEmpty(s))
			.Distinct()
			.OrderBy(s => s)
			.ToList();

		ApplyFilters();
	}

	private void ApplyFilters() {
		var filtered = AllRows.AsEnumerable();

		if (!string.IsNullOrEmpty(SelectedResource))
			filtered = filtered.Where(r => r.ResourceType == SelectedResource);
		if (SelectedDirection == "earned")
			filtered = filtered.Where(r => r.Amount > 0);
		else if (SelectedDirection == "spent")
			filtered = filtered.Where(r => r.Amount < 0);
		if (!string.IsNullOrEmpty(SelectedSource))
			filtered = filtered.Where(r => r.Source == SelectedSource);
		if (DateFrom.HasValue)
			filtered = filtered.Where(r => r.Timestamp >= DateFrom.Value);

		FilteredRows = filtered.ToList();

		// Calculate summaries
		TotalEarned = FilteredRows.Where(r => r.Amount > 0).Sum(r => (long)r.Amount);
		TotalSpent = FilteredRows.Where(r => r.Amount < 0).Sum(r => (long)r.Amount);
		NetChange = TotalEarned + TotalSpent;
		EarnedCount = FilteredRows.Count(r => r.Amount > 0);
		SpentCount = FilteredRows.Count(r => r.Amount < 0);
	}

	private void ClearFilters() {
		SelectedResource = "";
		SelectedDirection = "";
		SelectedSource = "";
		DateFrom = null;
		ApplyFilters();
	}

	/// <summary>
	/// Click a resource balance card to filter by that resource type.
	/// </summary>
	private void SelectResource(string resource) {
		SelectedResource = SelectedResource == resource ? "" : resource;
		ApplyFilters();
	}

	/// <summary>Formats source strings into friendly display names.</summary>
	private static string FormatSource(string source) {
		return source switch {
			"battle" => "Battle",
			"shop" => "Shop Purchase",
			"quest" => "Quest Reward",
			"chest" => "Chest Drop",
			"daily_reward" => "Daily Reward",
			"guild" => "Guild",
			"event" => "Event",
			"arena" => "Arena",
			"grand_arena" => "Grand Arena",
			"titan_arena" => "Titan Arena",
			"guild_war" => "Guild War",
			"guild_raid" => "Guild Raid",
			"expedition" => "Expedition",
			"tower" => "Tower",
			_ => source,
		};
	}

	/// <summary>Formats resource type to display name.</summary>
	private static string FormatResourceType(string type) {
		return type switch {
			"emeralds" => "Emeralds",
			"gold" => "Gold",
			"arena_coins" => "Arena",
			"grand_arena_coins" => "GA",
			"guild_coins" => "Guild",
			"tower_coins" => "Tower",
			"titan_coins" => "Titan",
			_ => type,
		};
	}

	/// <summary>Returns badge class for resource type.</summary>
	private static string GetResourceBadgeClass(string type) {
		return type switch {
			"emeralds" => "bg-success",
			"gold" => "bg-warning text-dark",
			"arena_coins" => "bg-primary",
			"grand_arena_coins" => "bg-info",
			"guild_coins" => "bg-secondary",
			"tower_coins" => "bg-dark",
			"titan_coins" => "bg-danger",
			_ => "bg-secondary",
		};
	}
}
