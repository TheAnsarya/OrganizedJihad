{
	"name": "organized-jihad",
	"version": "0.9.70",
	"description": "TamperMonkey userscript for tracking Hero Wars game data with UI overlay",
	"main": "dist/organized-jihad.user.js",
	"type": "module",
	"scripts": {
		"build": "webpack --mode production",
		"dev": "webpack --mode development --watch",
		"dev:serve": "node serve-dev.cjs",
		"lint": "eslint src/**/*.js",
		"format": "prettier --write \"src/**/*.{js,css,json}\"",
		"format:check": "prettier --check \"src/**/*.{js,css,json}\"",
		"test": "jest",
		"test:watch": "jest --watch",
		"test:coverage": "jest --coverage",
		"test:verbose": "jest --verbose"
	},
	"keywords": [
		"tampermonkey",
		"userscript",
		"hero-wars",
		"game-tracker"
	],
	"author": "Andy Hubbard <me@ansarya.com>",
	"license": "MIT",
	"devDependencies": {
		"@babel/core": "^7.23.5",
		"@babel/preset-env": "^7.28.3",
		"@testing-library/jest-dom": "^6.9.1",
		"babel-loader": "^9.1.3",
		"css-loader": "^6.8.1",
		"editorconfig": "^3.0.1",
		"eslint": "^8.54.0",
		"fake-indexeddb": "^6.2.4",
		"jest": "^30.2.0",
		"jest-environment-jsdom": "^30.2.0",
		"jsdom": "^27.0.1",
		"prettier": "^3.6.2",
		"style-loader": "^3.3.3",
		"webpack": "^5.89.0",
		"webpack-cli": "^5.1.4"
	},
	"engines": {
		"node": ">=18.0.0"
	}
}
