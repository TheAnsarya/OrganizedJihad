{
	"env": {
		"browser": true,
		"es2024": true,
		"greasemonkey": true
	},
	"extends": "eslint:recommended",
	"parserOptions": {
		"ecmaVersion": "latest",
		"sourceType": "module"
	},
	"rules": {
		"no-console": "off",
		"no-unused-vars": "warn",
		"indent": ["error", "tab"],
		"quotes": ["error", "single"],
		"semi": ["error", "always"],
		"no-tabs": "off"
	},
	"globals": {
		"GM_setValue": "readonly",
		"GM_getValue": "readonly",
		"GM_deleteValue": "readonly",
		"GM_listValues": "readonly",
		"GM_addStyle": "readonly",
		"unsafeWindow": "readonly"
	}
}
