# SCSS custom formatting rules (for reference, not all are supported by EditorConfig natively)

# Use double quotes for strings
scss_quotes = double

# Require space after colon in property
scss_space_after_colon = true

# Require space before opening brace
scss_space_before_brace = true

# Require space after comma in lists
scss_space_after_comma = true

# No trailing semicolon in last property
# scss_no_trailing_semicolon = true

# Require empty line before comment
scss_empty_line_before_comment = true

# Require empty line after comment
# scss_empty_line_after_comment = true

# No extra blank lines between rulesets
scss_no_extra_blank_lines = false

# Require space after // for inline comments
# scss_space_after_inline_comment = true

# Require space after /* for block comments
# scss_space_after_block_comment = true

# No trailing whitespace in selectors
scss_no_trailing_whitespace_in_selector = true

# Require newline between nested rules
scss_newline_between_nested_rules = true

# Require space before !important
scss_space_before_important = true

# Require space after !important
# scss_space_after_important = true

# Require space after mixin name
# scss_space_after_mixin_name = true

# Require space after function name
# scss_space_after_function_name = true

# Require space after variable name
# scss_space_after_variable_name = true

# Require space after @use/@import
# scss_space_after_use_import = true

# Require space after @include
# scss_space_after_include = true

# Require space after @extend
# scss_space_after_extend = true

# Require space after @if/@else/@for/@each/@while
# scss_space_after_control = true

# Require space after @return
# scss_space_after_return = true

# Require space after @error
# scss_space_after_error = true

# Require space after @warn
# scss_space_after_warn = true

# Require space after @debug
# scss_space_after_debug = true

