## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates
*.userprefs
.vs/*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/

!packages/*/build/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# Compiled objects
*_i.c
*_p.c
*.ilk
*.meta
*.obj
*.pch
*.pdb
*.pgc
*.pgd
*.rsp
*.sbr
*.tlb
*.tli
*.tlh
*.tmp
*.tmp_proj
*.log
*.vspscc
*.vssscc
.builds
*.pidb
*.scc

# Visual C++ cache files
ipch/
*.aps
*.ncb
*.opensdf
*.sdf
*.cachefile

# Visual Studio profiler
*.psess
*.vsp
*.vspx
*.sap

# Visual C++ database files
*.VC.opendb
*.VC.db
*.VC.db-wal
*.VC.db-shm

# Guidance Automation Toolkit
*.gpState

# ReSharper
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# TeamCity
_TeamCity*

# DotCover
*.dotCover

# NCrunch
*.ncrunch*
.*crunch*.local.xml

# Rider
.idea/
*.sln.iml

# Installshield
[Ee]xpress/

# DocProject
DocProject/buildhelp/
DocProject/Help/*.HxT
DocProject/Help/*.HxC
DocProject/Help/*.hhc
DocProject/Help/*.hhk
DocProject/Help/*.hhp
DocProject/Help/Html2
DocProject/Help/html

# Click-Once
publish/

# Publish Web Output
*.Publish.xml

# NuGet
*.nupkg
**/packages/*
!**/packages/build/
*.nuget.props
*.nuget.targets

# Windows Azure
csx
*.build.csdef

# Windows Store
AppPackages/

# Others
sql/
*.Cache
ClientBin/
[Ss]tyle[Cc]op.*
~$*
*~
*.dbmdl
*.[Pp]ublish.xml
*.pfx
*.publishsettings

# RIA/Silverlight
Generated_Code/

# Upgrade reports
_UpgradeReport_Files/
Backup*/
UpgradeLog*.XML
UpgradeLog*.htm

# SQL Server
App_Data/*.mdf
App_Data/*.ldf

# LightSwitch
GeneratedArtifacts/
_Pvt_Extensions/
ModelManifest.xml

# Node.js
node_modules/
dist/
.npm
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# SQLite database files (development)
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# MAUI specific
**/AppPackages/
**/*.appx
**/*.appxbundle
**/*.appxupload

# BenchmarkDotNet artifacts
BenchmarkDotNet.Artifacts/
benchmarks/BenchmarkDotNet.Artifacts/

# Build and test output files
bench-*.json
bench-*.txt
build-*.log
build-*.txt
build-output.txt
build-err*.txt
test-*.log
terminal-*.txt

# Release packaging output (generated)
artifacts/
installer-ui/bundle-payload/

# Windows detritus
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
**/.DS_Store

# VS Code - keep select config files
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Reference code (tracked separately)
~reference-code/

# Coverage output
coverage/
*.coverage
*.coveragexml
TestResults/
