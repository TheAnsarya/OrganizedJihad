<Window xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	x:Class="OrganizedJihad.Installer.MainWindow"
	Title="OrganizedJihad Installer"
	Width="980"
	Height="820"
	MinWidth="820"
	MinHeight="680">
	<ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
		<StackPanel Margin="18" Spacing="10">
			<TextBlock Text="OrganizedJihad One-Click Installer" FontSize="24" FontWeight="SemiBold" />
			<TextBlock Text="Guided setup for API server, desktop app, and userscript. No command prompt required." Opacity="0.85" />

			<Border BorderThickness="1" BorderBrush="#3A3A3A" CornerRadius="6" Padding="10">
				<StackPanel Spacing="4">
					<TextBlock Text="Quick Start" FontWeight="SemiBold" />
					<TextBlock Text="1. Step 1 checks/installs Tampermonkey for the selected browser." Opacity="0.85" />
					<TextBlock Text="2. Step 2 installs API server with tray icon startup (Plex-style hidden icon behavior)." Opacity="0.85" />
					<TextBlock Text="3. Step 3 installs desktop app, then Step 4 installs userscript (enabled only when Tampermonkey is detected, bypass available)." Opacity="0.85" />
				</StackPanel>
			</Border>

			<Grid ColumnDefinitions="180,*">
				<TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Install root" />
				<TextBox x:Name="InstallRootTextBox" Grid.Column="1" Margin="10,0,0,0" />
			</Grid>

			<Grid ColumnDefinitions="180,*">
				<TextBlock Grid.Column="0" VerticalAlignment="Center" Text="API URL" />
				<TextBox x:Name="ApiUrlTextBox" Grid.Column="1" Margin="10,0,0,0" />
			</Grid>

			<Grid ColumnDefinitions="180,*">
				<TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Target browser" />
				<ComboBox x:Name="BrowserComboBox" Grid.Column="1" Margin="10,0,0,0" SelectionChanged="OnBrowserSelectionChanged" />
			</Grid>

			<Border BorderThickness="1" BorderBrush="#3A3A3A" CornerRadius="6" Padding="10">
				<Grid ColumnDefinitions="260,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
					<Button x:Name="InstallTampermonkeyButton" Grid.Row="0" Grid.Column="0" Width="240" Height="34" HorizontalAlignment="Left" Content="Step 1: Install / Verify Tampermonkey" Click="OnInstallTampermonkeyClick" />
					<Button x:Name="InstallApiStepButton" Grid.Row="1" Grid.Column="0" Margin="0,8,0,0" Width="240" Height="34" HorizontalAlignment="Left" Content="Step 2: Install API Server" Click="OnInstallApiStepClick" />
					<Button x:Name="InstallDesktopStepButton" Grid.Row="2" Grid.Column="0" Margin="0,8,0,0" Width="240" Height="34" HorizontalAlignment="Left" Content="Step 3: Install Desktop App" Click="OnInstallDesktopStepClick" />
					<Button x:Name="InstallUserscriptStepButton" Grid.Row="3" Grid.Column="0" Margin="0,8,0,0" Width="240" Height="34" HorizontalAlignment="Left" Content="Step 4: Install Userscript" Click="OnInstallUserscriptStepClick" />
					<Button x:Name="InstallUserscriptBypassButton" Grid.Row="4" Grid.Column="0" Margin="0,8,0,0" Width="240" Height="34" HorizontalAlignment="Left" Content="Step 4b: Install Userscript (Bypass)" Click="OnInstallUserscriptBypassStepClick" />

					<StackPanel Grid.Row="0" Grid.Column="1" Grid.RowSpan="5" Margin="12,0,0,0" Spacing="6">
						<TextBlock Text="Step Status" FontWeight="SemiBold" />
						<TextBlock x:Name="TampermonkeyStatusTextBlock" Text="Tampermonkey status: checking..." Opacity="0.92" />
						<TextBlock Text="Userscript install button is enabled only when Tampermonkey is detected in the selected browser." Opacity="0.82" TextWrapping="Wrap" />
						<TextBlock Text="If detection misses your setup, use the bypass step and follow the setup guide screenshots." Opacity="0.82" TextWrapping="Wrap" />
					</StackPanel>
				</Grid>
			</Border>

			<WrapPanel Orientation="Horizontal" ItemWidth="300" ItemHeight="32">
				<CheckBox x:Name="OpenTampermonkeySetupCheckBox" Content="Open Tampermonkey setup page during userscript step" IsChecked="True" />
				<CheckBox x:Name="FirstRunDiagnosticsCheckBox" Content="Run first-run diagnostics" IsChecked="False" />
				<CheckBox x:Name="OpenDiagnosticsCheckBox" Content="Open diagnostics pages after install" IsChecked="False" />
			</WrapPanel>

			<Border BorderThickness="1" BorderBrush="#3A3A3A" CornerRadius="6" Padding="8">
				<TextBox x:Name="LogTextBox"
					Height="260"
					IsReadOnly="True"
					AcceptsReturn="True"
					TextWrapping="Wrap"
					ScrollViewer.VerticalScrollBarVisibility="Auto"
					ScrollViewer.HorizontalScrollBarVisibility="Auto"
					FontFamily="Consolas"
					Text="Ready. Choose components, then click Install Ecosystem." />
			</Border>

			<Grid ColumnDefinitions="*,Auto,Auto" RowDefinitions="Auto">
				<TextBlock x:Name="StatusTextBlock" VerticalAlignment="Center" Text="Status: Idle" />
				<Button x:Name="InstallButton" Grid.Column="1" Margin="10,0,0,0" Content="Run Full Install" Width="200" Height="36" Click="OnInstallClick" />
				<Button x:Name="OpenInstallRootButton" Grid.Column="2" Margin="10,0,0,0" Content="Open Install Folder" Width="170" Height="36" Click="OnOpenInstallRootClick" />
			</Grid>

			<Grid ColumnDefinitions="*,Auto,Auto" RowDefinitions="Auto">
				<TextBlock x:Name="LogPathTextBlock" VerticalAlignment="Center" Opacity="0.85" Text="Log: pending" />
				<Button x:Name="OpenSetupGuideButton" Grid.Column="1" Margin="10,0,0,0" Content="Open Setup Guide" Width="150" Height="32" Click="OnOpenSetupGuideClick" />
				<Button x:Name="OpenLogFolderButton" Grid.Column="2" Margin="10,0,0,0" Content="Open Log Folder" Width="170" Height="32" Click="OnOpenLogFolderClick" />
			</Grid>
		</StackPanel>
	</ScrollViewer>
</Window>
