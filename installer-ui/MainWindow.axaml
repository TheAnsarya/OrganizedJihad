<Window xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	x:Class="OrganizedJihad.Installer.MainWindow"
	Title="OrganizedJihad Installer"
	Width="900"
	Height="700"
	MinWidth="760"
	MinHeight="620">
	<Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,*,Auto,Auto" Margin="18">
		<TextBlock Grid.Row="0" Margin="0,0,0,10" Text="OrganizedJihad One-Click Installer" FontSize="24" FontWeight="SemiBold" />
		<TextBlock Grid.Row="1" Margin="0,0,0,10" Text="Guided setup for API server, desktop app, and userscript. No command prompt required." Opacity="0.85" />

		<Border Grid.Row="2" Margin="0,0,0,10" BorderThickness="1" BorderBrush="#3A3A3A" CornerRadius="6" Padding="10">
			<StackPanel Spacing="4">
				<TextBlock Text="Quick Start" FontWeight="SemiBold" />
				<TextBlock Text="1. Choose components and a browser target (if installing userscript)." Opacity="0.85" />
				<TextBlock Text="2. Click Install Ecosystem and wait for Status: Install complete." Opacity="0.85" />
				<TextBlock Text="3. If userscript is selected, follow the import steps shown in the log." Opacity="0.85" />
			</StackPanel>
		</Border>

		<Grid Grid.Row="3" Margin="0,0,0,10" ColumnDefinitions="180,*">
			<TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Install root" />
			<TextBox x:Name="InstallRootTextBox" Grid.Column="1" Margin="10,0,0,0" />
		</Grid>

		<Grid Grid.Row="4" Margin="0,0,0,10" ColumnDefinitions="180,*">
			<TextBlock Grid.Column="0" VerticalAlignment="Center" Text="API URL" />
			<TextBox x:Name="ApiUrlTextBox" Grid.Column="1" Margin="10,0,0,0" />
		</Grid>

		<Grid Grid.Row="5" Margin="0,0,0,10" ColumnDefinitions="180,*">
			<TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Target browser" />
			<ComboBox x:Name="BrowserComboBox" Grid.Column="1" Margin="10,0,0,0" />
		</Grid>

		<StackPanel Grid.Row="6" Margin="0,0,0,10" Orientation="Horizontal" Spacing="20">
			<CheckBox x:Name="InstallApiCheckBox" Content="Install API server" IsChecked="True" Checked="OnInstallOptionChanged" Unchecked="OnInstallOptionChanged" />
			<CheckBox x:Name="InstallDesktopCheckBox" Content="Install desktop app" IsChecked="True" Checked="OnInstallOptionChanged" Unchecked="OnInstallOptionChanged" />
			<CheckBox x:Name="InstallUserscriptCheckBox" Content="Install userscript" IsChecked="True" Checked="OnInstallOptionChanged" Unchecked="OnInstallOptionChanged" />
		</StackPanel>

		<StackPanel Grid.Row="7" Margin="0,0,0,10" Orientation="Horizontal" Spacing="20">
			<CheckBox x:Name="OpenTampermonkeySetupCheckBox" Content="Open Tampermonkey setup page" IsChecked="True" Checked="OnInstallOptionChanged" Unchecked="OnInstallOptionChanged" />
			<CheckBox x:Name="FirstRunDiagnosticsCheckBox" Content="Run first-run diagnostics" IsChecked="True" />
			<CheckBox x:Name="OpenDiagnosticsCheckBox" Content="Open diagnostics pages after install" IsChecked="True" />
		</StackPanel>

		<Border Grid.Row="8" Margin="0,0,0,10" BorderThickness="1" BorderBrush="#3A3A3A" CornerRadius="6" Padding="8">
			<TextBox x:Name="LogTextBox"
				IsReadOnly="True"
				AcceptsReturn="True"
				TextWrapping="Wrap"
				ScrollViewer.VerticalScrollBarVisibility="Auto"
				ScrollViewer.HorizontalScrollBarVisibility="Auto"
				FontFamily="Consolas"
				Text="Ready. Choose components, then click Install Ecosystem." />
		</Border>

		<Grid Grid.Row="9" Margin="0,0,0,10" ColumnDefinitions="*,Auto,Auto">
			<TextBlock x:Name="StatusTextBlock" VerticalAlignment="Center" Text="Status: Idle" />
			<Button x:Name="InstallButton" Grid.Column="1" Margin="10,0,0,0" Content="Install Ecosystem" Width="200" Height="36" Click="OnInstallClick" />
			<Button x:Name="OpenInstallRootButton" Grid.Column="2" Margin="10,0,0,0" Content="Open Install Folder" Width="170" Height="36" Click="OnOpenInstallRootClick" />
		</Grid>

		<Grid Grid.Row="10" ColumnDefinitions="*,Auto">
			<TextBlock x:Name="LogPathTextBlock" VerticalAlignment="Center" Opacity="0.85" Text="Log: pending" />
			<Button x:Name="OpenLogFolderButton" Grid.Column="1" Margin="10,0,0,0" Content="Open Log Folder" Width="170" Height="32" Click="OnOpenLogFolderClick" />
		</Grid>
	</Grid>
</Window>
